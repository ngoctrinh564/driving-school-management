@model driving_school_management.Models.DTOs.KyThiEditDto

@{
    ViewData["Title"] = "Sửa cặp kỳ thi";
    var hangList = ViewBag.HangList as List<driving_school_management.Models.DTOs.HangGplxDto>;
}

<div class="card-custom">
    <h4 class="fw-bold mb-3">Sửa cặp kỳ thi</h4>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kyThiId" value="@Model.KyThiId" />

        <div class="form-group mb-3">
            <label>Chọn hạng</label>
            <select name="hangId" class="form-control input-custom">
                @if (hangList != null)
                {
                    foreach (var h in hangList)
                    {
                        if (h.HangId == Model.HangId)
                        {
                            <option value="@h.HangId" selected>@h.TenHang (@h.MaHang)</option>
                        }
                        else
                        {
                            <option value="@h.HangId">@h.TenHang (@h.MaHang)</option>
                        }
                    }
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Đợt</label>
            <input name="dot" class="form-control input-custom" value="@Model.Dot" />
        </div>

        <div class="form-group mb-3">
            <label>Năm</label>
            <input name="nam" class="form-control input-custom" value="@Model.Nam" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-custom">
                <i class="bi bi-check-circle"></i> Lưu
            </button>
            <a asp-action="Index" class="btn btn-light btn-custom">
                Quay lại
            </a>
        </div>
    </form>
</div>
@model List<driving_school_management.Models.DTOs.KyThiDto>

@{
    ViewData["Title"] = "Quản lý kỳ thi";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold">Danh sách kỳ thi</h3>
    <a asp-action="Create" class="btn btn-primary btn-custom">
        <i class="bi bi-plus-circle"></i> Tạo kỳ thi
    </a>
</div>

<div class="card-custom">
    <table class="table table-custom">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên kỳ thi</th>
                <th>Loại</th>
                <th>Hạng</th>
                <th>Số lượng</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.KyThiId</td>
                    <td>@item.TenKyThi</td>
                    <td>@item.LoaiKyThi</td>
                    <td><span class="badge bg-primary">@item.MaHang</span></td>
                    <td>@item.SoLuongDangKy</td>
                    <td class="text-end">
                        <a asp-action="Schedules" asp-route-kyThiId="@item.KyThiId" class="btn btn-sm btn-outline-primary">Lịch thi</a>
                        <a asp-action="RegisteredStudents" asp-route-kyThiId="@item.KyThiId" class="btn btn-sm btn-outline-secondary">Học viên</a>
                        <a asp-action="Edit" asp-route-kyThiId="@item.KyThiId" class="btn btn-sm btn-outline-warning">Sửa</a>
                        <form asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="kyThiId" value="@item.KyThiId" />
                            <button class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
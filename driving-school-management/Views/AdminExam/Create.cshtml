@{
    ViewData["Title"] = "Thêm kỳ thi";
}

<div class="container">
    <div class="card">
        <h2>Thêm kỳ thi</h2>

        <form method="post">
            <div class="form-group">
                <label>Tên kỳ thi</label>
                <input name="tenKyThi" class="input" />
            </div>

            <div class="form-group">
                <label>Loại kỳ thi</label>
                <input name="loaiKyThi" class="input" />
            </div>

            <button class="btn-primary">Lưu</button>
        </form>
    </div>
</div>

<style>
.container { padding:20px; }
.card { background:#fff; padding:20px; border-radius:16px; box-shadow:0 2px 8px rgba(0,0,0,0.05); }
.input { width:100%; padding:10px; border:1px solid #e5e7eb; border-radius:8px; margin-top:6px; }
.form-group { margin-bottom:16px; }
.btn-primary { background:#2563eb; color:#fff; padding:10px 16px; border:none; border-radius:10px; }
</style>
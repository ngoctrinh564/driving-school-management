@{
    ViewData["Title"] = "Tạo kỳ thi";
    var hangList = ViewBag.HangList as List<driving_school_management.Models.DTOs.HangGplxDto>;
}

<div class="card-custom">
    <h4 class="fw-bold mb-3">Tạo kỳ thi</h4>

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label>Chọn hạng</label>
            <select name="hangId" class="form-control input-custom">
                @foreach (var h in hangList)
                {
                    <option value="@h.HangId">@h.TenHang (@h.MaHang)</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Đợt</label>
            <input name="dot" class="form-control input-custom" />
        </div>

        <div class="form-group">
            <label>Năm</label>
            <input name="nam" class="form-control input-custom" />
        </div>

        <button class="btn btn-primary btn-custom mt-3">
            <i class="bi bi-check"></i> Tạo
        </button>
    </form>
</div>
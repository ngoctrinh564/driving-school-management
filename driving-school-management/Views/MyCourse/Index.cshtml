    async function openCourseDetail(khoaHocId) {
        const dialog = document.getElementById('detailDialog');
        const loading = document.getElementById('dialogLoading');
        const content = document.getElementById('dialogContent');

        dialog.style.display = 'flex';
        loading.style.display = 'block';
        content.innerHTML = '';

        try {
            const response = await fetch('/MyCourse/GetMyCourseDetail?khoaHocId=' + khoaHocId);
            if (!response.ok) {
                throw new Error('Không thể tải chi tiết khóa học.');
            }

            const data = await response.json();
            loading.style.display = 'none';
            content.innerHTML = buildDetailDialog(data);
        } catch (error) {
            loading.style.display = 'none';
            content.innerHTML = '';
            showToast(error.message || 'Đã xảy ra lỗi.');
        }
    }

    async function loadMyCourses() {
        const loadingShell = document.getElementById('loadingShell');
        const tableWrap = document.getElementById('tableWrap');
        const emptyBox = document.getElementById('emptyBox');

        loadingShell.style.display = 'block';
        tableWrap.style.display = 'none';
        emptyBox.style.display = 'none';

        try {
            const response = await fetch('/MyCourse/GetMyCourses');
            if (!response.ok) {
                throw new Error('Không thể tải danh sách khóa học.');
            }

            const data = await response.json();
            allCourses = Array.isArray(data) ? data : [];

            loadingShell.style.display = 'none';
            updateSummaryMetrics(allCourses);
            applyFilterAndRender();
        } catch (error) {
            loadingShell.style.display = 'none';
            allCourses = [];
            updateSummaryMetrics([]);
            renderTable([]);
            showToast(error.message || 'Đã xảy ra lỗi.');
        }
    }

    function applyFilterAndRender() {
        renderTable(getFilteredCourses());
    }

    document.getElementById('courseSearchInput').addEventListener('input', function () {
        applyFilterAndRender();
    });

    document.getElementById('btnOpenOverview').onclick = function () {
        document.getElementById('overviewDialog').style.display = 'flex';
    };

    document.getElementById('btnCloseOverview').onclick = function () {
        document.getElementById('overviewDialog').style.display = 'none';
    };

    document.getElementById('btnCloseDialog').onclick = function () {
        document.getElementById('detailDialog').style.display = 'none';
    };

    document.getElementById('overviewDialog').onclick = function (e) {
        if (e.target.id === 'overviewDialog') {
            document.getElementById('overviewDialog').style.display = 'none';
        }
    };

    document.getElementById('detailDialog').onclick = function (e) {
        if (e.target.id === 'detailDialog') {
            document.getElementById('detailDialog').style.display = 'none';
        }
    };

    bindFilterTabs();
    loadMyCourses();
</script>
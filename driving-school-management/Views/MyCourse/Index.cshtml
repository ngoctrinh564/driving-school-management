<div id="toastBox" class="toast-box"></div>

<script>
    let allCourses = [];
    let currentFilter = 'ALL';

    function escapeHtml(value) {
        if (value === null || value === undefined) return '';
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatDate(value) {
        if (!value) return '—';
        const date = new Date(value);
        if (isNaN(date.getTime())) return '—';
        return date.toLocaleDateString('vi-VN');
    }

    function formatDateTime(value) {
        if (!value) return '—';
        const date = new Date(value);
        if (isNaN(date.getTime())) return '—';
        return date.toLocaleString('vi-VN');
    }

    function formatMoney(value) {
        return Number(value || 0).toLocaleString('vi-VN') + ' VNĐ';
    }

    function showToast(message) {
        const toast = document.getElementById('toastBox');
        toast.textContent = message || 'Đã xảy ra lỗi.';
        toast.style.display = 'block';
        setTimeout(() => {
            toast.style.display = 'none';
        }, 2500);
    }

    function getStatusChip(status) {
        const s = (status || '').trim();

        if (s === 'Hoàn thành') return `<span class="soft-chip chip-success">${escapeHtml(s)}</span>`;
        if (s === 'Đang học') return `<span class="soft-chip chip-info">${escapeHtml(s)}</span>`;
        if (s === 'Không hoàn thành') return `<span class="soft-chip chip-danger">${escapeHtml(s)}</span>`;
        return `<span class="soft-chip chip-neutral">${escapeHtml(s || 'Chưa xác định')}</span>`;
    }

    function getPaymentMethodChip(method) {
        const m = (method || '').trim();
        if (!m) return `<span class="soft-chip chip-neutral">Chưa rõ</span>`;
        return `<span class="soft-chip chip-neutral">${escapeHtml(m)}</span>`;
    }

    function getResultBadge(value, label) {
        const isDone = Number(value || 0) === 1;
        return `<span class="progress-mini ${isDone ? 'done' : 'pending'}" title="${escapeHtml(label)}">${isDone ? 'Đạt' : 'Chưa'}</span>`;
    }

    function updateSummaryMetrics(source) {
        const total = source.length;
        const completed = source.filter(x => (x.trangThaiHocTap || '') === 'Hoàn thành').length;
        const active = source.filter(x => (x.trangThaiHocTap || '') === 'Đang học').length;
        const failed = source.filter(x => (x.trangThaiHocTap || '') === 'Không hoàn thành').length;

        document.getElementById('summaryTotal').textContent = total;
        document.getElementById('summaryCompleted').textContent = completed;
        document.getElementById('summaryActive').textContent = active;
        document.getElementById('summaryFailed').textContent = failed;
        document.getElementById('summaryPaid').textContent = total;
    }

    function updateFilteredMetrics(source) {
        const total = source.length;
        const completed = source.filter(x => (x.trangThaiHocTap || '') === 'Hoàn thành').length;
        const active = source.filter(x => (x.trangThaiHocTap || '') === 'Đang học').length;
        const failed = source.filter(x => (x.trangThaiHocTap || '') === 'Không hoàn thành').length;

        document.getElementById('recordCountChip').textContent = `${total} khóa học`;
        document.getElementById('metricMainValue').textContent = total;
        document.getElementById('metricCompleted').textContent = completed;
        document.getElementById('metricActive').textContent = active;
        document.getElementById('metricFailed').textContent = failed;
    }

    function getFilteredCourses() {
        const keyword = (document.getElementById('courseSearchInput').value || '').trim().toLowerCase();

        return allCourses.filter(item => {
            const statusMatch = currentFilter === 'ALL' || (item.trangThaiHocTap || '') === currentFilter;

            const haystack = [
                item.tenKhoaHoc,
                item.tenHang,
                item.tenHoSo,
                item.hoTenHocVien,
                item.tenPhieu,
                item.phuongThuc,
                item.loaiPhuongTien
            ]
            .map(x => (x || '').toString().toLowerCase())
            .join(' | ');

            const keywordMatch = !keyword || haystack.includes(keyword);
            return statusMatch && keywordMatch;
        });
    }

    function renderTable(source) {
        const tbody = document.getElementById('courseTableBody');
        const emptyBox = document.getElementById('emptyBox');
        const tableWrap = document.getElementById('tableWrap');

        tbody.innerHTML = '';

        if (!source || source.length === 0) {
            tableWrap.style.display = 'none';
            emptyBox.style.display = 'block';
            updateFilteredMetrics([]);
            return;
        }

        emptyBox.style.display = 'none';
        tableWrap.style.display = 'block';

        source.forEach(item => {
            const row = `
                <tr onclick="openCourseDetail(${item.khoaHocId})">
                    <td>
                        <div class="course-main">
                            <div class="course-name">${escapeHtml(item.tenKhoaHoc || '')}</div>
                            <div class="course-sub">${escapeHtml(item.diaDiem || '')}</div>
                        </div>
                    </td>
                    <td>
                        <div class="meta-stack">
                            <div class="meta-primary">${escapeHtml(item.tenHang || '')}</div>
                            <div class="meta-secondary">${escapeHtml(item.loaiPhuongTien || '')}</div>
                        </div>
                    </td>
                    <td>
                        <div class="meta-stack">
                            <div class="meta-primary">${escapeHtml(item.tenHoSo || '')}</div>
                            <div class="meta-secondary">${escapeHtml(item.hoTenHocVien || '')}</div>
                        </div>
                    </td>
                    <td>
                        <div class="meta-stack">
                            <div class="meta-primary">${formatDate(item.ngayBatDau)} - ${formatDate(item.ngayKetThuc)}</div>
                            <div class="meta-secondary">${escapeHtml(item.trangThaiKhoaHocGoc || '')}</div>
                        </div>
                    </td>
                    <td>
                        <div class="progress-group">
                            ${getResultBadge(item.lyThuyetKq, 'Lý thuyết')}
                            ${getResultBadge(item.saHinhKq, 'Sa hình')}
                            ${getResultBadge(item.duongTruongKq, 'Đường trường')}
                            ${getResultBadge(item.moPhongKq, 'Mô phỏng')}
                        </div>
                    </td>
                    <td>${getStatusChip(item.trangThaiHocTap)}</td>
                    <td>
                        <div class="meta-stack">
                            <div class="money">${formatMoney(item.tongTien)}</div>
                            <div class="meta-secondary">${getPaymentMethodChip(item.phuongThuc)}</div>
                        </div>
                    </td>
                    // <td><span class="action-hint">     </span></td>
                </tr>
            `;
            tbody.insertAdjacentHTML('beforeend', row);
        });

        updateFilteredMetrics(source);
    }

    function applyFilterAndRender() {
        renderTable(getFilteredCourses());
    }

    function bindFilterTabs() {
        document.querySelectorAll('.filter-tab').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.filter-tab').forEach(x => x.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.getAttribute('data-filter') || 'ALL';
                applyFilterAndRender();
            });
        });
    }

    function buildDetailDialog(d) {
        const getState = (v) => Number(v || 0) === 1 ? 'pass' : 'fail';
        const getStateText = (v) => Number(v || 0) === 1 ? 'Đạt' : 'Chưa đạt';

        return `
            <div class="detail-top">
                <div class="detail-hero">
                    <div class="detail-kicker">Khóa học đã đăng ký</div>
                    <h4 class="detail-course-name">${escapeHtml(d.tenKhoaHoc || '')}</h4>
                    <div class="detail-course-desc">
                        ${escapeHtml(d.moTa || 'Thông tin chi tiết của khóa học, học viên, hồ sơ, thanh toán và kết quả học tập hiện tại.')}
                    </div>

                    <div class="detail-pill-row">
                        <span class="soft-chip chip-neutral">#${escapeHtml(d.khoaHocId)}</span>
                        <span class="soft-chip chip-neutral">${escapeHtml(d.tenHang || '')}</span>
                        <span class="soft-chip chip-neutral">${escapeHtml(d.loaiPhuongTien || '')}</span>
                        ${getStatusChip(d.trangThaiHocTap || 'Chưa bắt đầu')}
                    </div>
                </div>

                <div class="detail-side">
                    <div class="side-label">Trạng thái hiện tại</div>
                    <p class="side-value">${escapeHtml(d.trangThaiHocTap || 'Chưa bắt đầu')}</p>

                    <div class="side-note">
                        Phiếu: <strong>#${escapeHtml(d.phieuId)}</strong><br/>
                        Học viên: <strong>${escapeHtml(d.hoTenHocVien || '')}</strong><br/>
                        Tài khoản: <strong>${escapeHtml(d.userName || '')}</strong>
                    </div>

                    <div class="side-group">
                        <div class="side-mini">
                            <div class="mini-label">Bắt đầu</div>
                            <div class="mini-value">${formatDate(d.ngayBatDau)}</div>
                        </div>
                        <div class="side-mini">
                            <div class="mini-label">Kết thúc</div>
                            <div class="mini-value">${formatDate(d.ngayKetThuc)}</div>
                        </div>
                        <div class="side-mini">
                            <div class="mini-label">Thanh toán</div>
                            <div class="mini-value">${formatMoney(d.tongTien)}</div>
                        </div>
                        <div class="side-mini">
                            <div class="mini-label">Phương thức</div>
                            <div class="mini-value">${escapeHtml(d.phuongThuc || '—')}</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== KẾT QUẢ HỌC TẬP ===================== -->
            <div class="info-section">
                <h5 class="info-title">Kết quả học tập</h5>

                <div class="result-summary-grid">
                    <div class="result-box">
                        <div class="result-label">#KQHT</div>
                        <div class="info-value">#${escapeHtml(d.ketQuaHocTapId)}</div>
                    </div>

                    <div class="result-box">
                        <div class="result-label">Lý thuyết</div>
                        <div class="result-state ${getState(d.lyThuyetKq)}">
                            ${getStateText(d.lyThuyetKq)}
                        </div>
                    </div>

                    <div class="result-box">
                        <div class="result-label">Sa hình</div>
                        <div class="result-state ${getState(d.saHinhKq)}">
                            ${getStateText(d.saHinhKq)}
                        </div>
                    </div>

                    <div class="result-box">
                        <div class="result-label">Đường trường</div>
                        <div class="result-state ${getState(d.duongTruongKq)}">
                            ${getStateText(d.duongTruongKq)}
                        </div>
                    </div>

                    <div class="result-box">
                        <div class="result-label">Mô phỏng</div>
                        <div class="result-state ${getState(d.moPhongKq)}">
                            ${getStateText(d.moPhongKq)}
                        </div>
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-card">
                        <div class="info-label">Số buổi học</div>
                        <div class="info-value soft">${escapeHtml(d.soBuoiHoc ?? '—')}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Số buổi vắng</div>
                        <div class="info-value soft">${escapeHtml(d.soBuoiVang ?? '—')}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Km hoàn thành</div>
                        <div class="info-value soft">${escapeHtml(d.soKmHoanThanh || '—')}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Trạng thái</div>
                        <div class="info-value">${escapeHtml(d.trangThaiHocTap || 'Chưa bắt đầu')}</div>
                    </div>

                    <div class="info-card wide">
                        <div class="info-label">Nhận xét</div>
                        <div class="info-value soft">${escapeHtml(d.nhanXet || '')}</div>
                    </div>
                </div>
            </div>

            <!-- ===================== KHÓA HỌC ===================== -->
            <div class="info-section">
                <h5 class="info-title">Thông tin khóa học</h5>

                <div class="info-grid">
                    <div class="info-card">
                        <div class="info-label">Tên khóa</div>
                        <div class="info-value">${escapeHtml(d.tenKhoaHoc)}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Hạng</div>
                        <div class="info-value">${escapeHtml(d.tenHang)}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Địa điểm</div>
                        <div class="info-value soft">${escapeHtml(d.diaDiem)}</div>
                    </div>

                    <div class="info-card">
                        <div class="info-label">Phương tiện</div>

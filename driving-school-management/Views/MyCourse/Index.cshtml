@{
    ViewData["Title"] = "Khóa học của tôi";
}

<style>
    :root {
        --bg: #f6f7f9;
        --surface: #ffffff;
        --surface-soft: #fbfcfd;
        --surface-strong: #f8fafc;
        --text: #0f172a;
        --text-soft: #475569;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --border-strong: #d7dee8;
        --shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.03);
        --shadow-sm: 0 8px 24px rgba(15, 23, 42, 0.05);
        --shadow-md: 0 20px 50px rgba(15, 23, 42, 0.10);
        --radius-xl: 26px;
        --radius-lg: 20px;
        --radius-md: 16px;
        --radius-sm: 12px;

        --success-bg: #ecfdf3;
        --success-text: #166534;
        --warning-bg: #fff7ed;
        --warning-text: #c2410c;
        --danger-bg: #fef2f2;
        --danger-text: #b91c1c;
        --info-bg: #eff6ff;
        --info-text: #1d4ed8;

        --dark-card: #111827;
        --dark-card-soft: #1f2937;
        --dark-card-text: #f8fafc;

        --transition: 0.22s ease;
    }

    body {
        background:
            radial-gradient(circle at top left, rgba(255,255,255,0.76), transparent 28%),
            linear-gradient(180deg, #f8fafc 0%, #f4f6f8 100%);
        color: var(--text);
        font-family: "Segoe UI", Arial, sans-serif;
    }

    .my-course-page {
        max-width: 1440px;
        margin: 0 auto;
        padding: 28px;
    }

    .page-header {
        margin-bottom: 22px;
    }

    .page-header-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
    }

    .page-title {
        margin: 0;
        font-size: 34px;
        line-height: 1.1;
        font-weight: 780;
        letter-spacing: -0.04em;
        color: var(--text);
    }

    .page-desc {
        margin-top: 12px;
        max-width: 860px;
        font-size: 14px;
        line-height: 1.85;
        color: var(--text-soft);
    }

    .page-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .overview-btn {
        appearance: none;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        min-height: 46px;
        padding: 0 16px;
        border-radius: 14px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all var(--transition);
        box-shadow: var(--shadow-xs);
    }

    .overview-btn:hover {
        border-color: var(--border-strong);
        background: var(--surface-soft);
        box-shadow: var(--shadow-sm);
        transform: translateY(-1px);
    }

    .section-shell {
        background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(252,252,253,0.98));
        border: 1px solid rgba(226,232,240,.95);
        border-radius: 26px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .section-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 22px 24px 18px;
        border-bottom: 1px solid #edf2f7;
        background: linear-gradient(180deg, rgba(255,255,255,0.9), rgba(248,250,252,0.72));
    }

    .section-title {
        margin: 0;
        font-size: 20px;
        line-height: 1.3;
        font-weight: 760;
        color: var(--text);
        letter-spacing: -0.03em;
    }

    .section-desc {
        margin-top: 7px;
        font-size: 13px;
        line-height: 1.7;
        color: var(--text-muted);
        max-width: 760px;
    }

    .section-note-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        color: var(--text-soft);
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .toolbar-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding: 18px 24px 0;
    }

    .search-box {
        flex: 1 1 360px;
        position: relative;
    }

    .search-box input {
        width: 100%;
        height: 48px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        padding: 0 16px;
        outline: none;
        font-size: 14px;
        color: var(--text);
        transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
    }

    .search-box input::placeholder {
        color: #94a3b8;
    }

    .search-box input:focus {
        border-color: #cbd5e1;
        box-shadow: 0 0 0 4px rgba(148, 163, 184, 0.10);
    }

    .filter-tabs {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .filter-tab {
        appearance: none;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-soft);
        min-height: 44px;
        padding: 0 15px;
        border-radius: 14px;
        font-size: 13px;
        font-weight: 700;
        transition: all var(--transition);
        cursor: pointer;
    }

    .filter-tab:hover {
        border-color: var(--border-strong);
        background: var(--surface-soft);
    }

    .filter-tab.active {
        background: var(--text);
        color: #fff;
        border-color: var(--text);
    }

    .metric-strip {
        display: grid;
        grid-template-columns: 1.25fr repeat(3, minmax(0, 1fr));
        gap: 14px;
        padding: 18px 24px 24px;
    }

    .metric-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 18px;
        box-shadow: var(--shadow-xs);
        transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }

    .metric-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
        border-color: var(--border-strong);
    }

    .metric-card.primary {
        padding: 22px 20px 18px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
    }

    .metric-label {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .10em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .metric-value {
        margin: 0;
        font-size: 32px;
        line-height: 1;
        letter-spacing: -0.04em;
        font-weight: 800;
        color: var(--text);
    }

    .metric-card:not(.primary) .metric-value {
        font-size: 28px;
    }

    .metric-note {
        margin-top: 10px;
        color: var(--text-soft);
        font-size: 13px;
        line-height: 1.6;
    }

    .table-wrap {
        padding: 0 24px 24px;
    }

    .table-shell {
        border: 1px solid var(--border);
        border-radius: 22px;
        overflow: hidden;
        background: #fff;
    }

    .table-scroll {
        width: 100%;
        overflow: auto;
        max-height: 720px;
    }

    .my-table {
        width: 100%;
        min-width: 1360px;
        border-collapse: separate;
        border-spacing: 0;
    }

    .my-table thead th {
        position: sticky;
        top: 0;
        z-index: 3;
        background: rgba(248, 250, 252, 0.96);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        padding: 16px 18px;
        text-align: left;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .10em;
        text-transform: uppercase;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .my-table tbody tr {
        transition: background var(--transition);
        cursor: pointer;
    }

    .my-table tbody tr:hover {
        background: #fafbfd;
    }

    .my-table tbody td {
        padding: 18px;
        border-bottom: 1px solid #eff3f8;
        vertical-align: middle;
        font-size: 14px;
        color: var(--text);
    }

    .my-table tbody tr:last-child td {
        border-bottom: none;
    }

    .course-main {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .course-name {
        font-size: 15px;
        font-weight: 760;
        line-height: 1.45;
        color: var(--text);
    }

    .course-sub {
        font-size: 12px;
        color: var(--text-muted);
    }

    .meta-stack {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .meta-primary {
        font-weight: 680;
        color: var(--text);
        white-space: nowrap;
    }

    .meta-secondary {
        font-size: 12px;
        color: var(--text-muted);
    }

    .money {
        font-weight: 780;
        color: var(--text);
        white-space: nowrap;
    }

    .soft-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .chip-success {
        background: var(--success-bg);
        color: var(--success-text);
        border-color: #dcfce7;
    }

    .chip-warning {
        background: var(--warning-bg);
        color: var(--warning-text);
        border-color: #fed7aa;
    }

    .chip-danger {
        background: var(--danger-bg);
        color: var(--danger-text);
        border-color: #fecaca;
    }

    .chip-info {
        background: var(--info-bg);
        color: var(--info-text);
        border-color: #bfdbfe;
    }

    .chip-neutral {
        background: #f8fafc;
        color: var(--text-soft);
        border-color: var(--border);
    }

    .progress-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .progress-mini {
        min-width: 34px;
        height: 30px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .02em;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-soft);
    }

    .progress-mini.done {
        background: var(--success-bg);
        color: var(--success-text);
        border-color: #dcfce7;
    }

    .progress-mini.pending {
        background: #f8fafc;
        color: #64748b;
        border-color: #e2e8f0;
    }

    .action-hint {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .empty-box {
        display: none;
        margin: 0 24px 24px;
        border-radius: 22px;
        border: 1px dashed #cfd8e3;
        background: rgba(255,255,255,0.84);
        text-align: center;
        padding: 74px 24px;
    }

    .empty-box h4 {
        margin: 0;
        font-size: 22px;
        font-weight: 760;
        color: var(--text);
        letter-spacing: -0.03em;
    }

    .empty-box p {
        margin: 12px auto 0;
        max-width: 520px;
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.8;
    }

    .loading-shell {
        padding: 0 24px 24px;
    }

    .skeleton-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .skeleton-line {
        height: 64px;
        border-radius: 18px;
        background: linear-gradient(90deg, #eef2f7, #f8fafc, #eef2f7);
        background-size: 200% 100%;
        animation: shimmer 1.3s linear infinite;
    }

    .dialog-backdrop {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: rgba(15, 23, 42, 0.28);
        backdrop-filter: blur(12px);
        display: none;
        align-items: flex-start;
        justify-content: center;
        overflow-y: auto;
        padding: 84px 20px 24px;
        animation: fadeIn .22s ease;
        box-sizing: border-box;
    }

    .dialog-panel {
        width: min(1320px, calc(100vw - 28px));
        max-height: calc(100vh - 108px);
        overflow: auto;
        background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(251,252,253,0.98));
        border: 1px solid rgba(226,232,240,.96);
        border-radius: 30px;
        box-shadow: 0 30px 80px rgba(15, 23, 42, 0.14);
        animation: popIn .24s ease forwards;
    }

    .dialog-head {
        position: sticky;
        top: 0;
        z-index: 5;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        padding: 24px 26px 18px;
        border-bottom: 1px solid #edf2f7;
        background: rgba(255,255,255,0.94);
        backdrop-filter: blur(14px);
    }

    .dialog-title {
        margin: 0;
        font-size: 30px;
        font-weight: 780;
        letter-spacing: -0.04em;
        color: var(--text);
    }

    .dialog-desc {
        margin-top: 8px;
        font-size: 14px;
        color: var(--text-muted);
    }

    .dialog-close {
        appearance: none;
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        font-size: 22px;
        cursor: pointer;
        transition: all var(--transition);
        flex-shrink: 0;
    }

    .dialog-close:hover {
        background: #f8fafc;
        border-color: var(--border-strong);
    }

    .dialog-body {
        padding: 24px 26px 26px;
    }

    .overview-panel {
        width: min(920px, calc(100vw - 28px));
        max-height: calc(100vh - 108px);
    }

    .overview-content {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 360px);
        gap: 16px;
    }

    .overview-hero {
        background: linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
    }

    .overview-kicker {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .10em;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .overview-title {
        margin: 0;
        font-size: 30px;
        font-weight: 780;
        line-height: 1.2;
        letter-spacing: -0.04em;
        color: var(--text);
    }

    .overview-desc {
        margin-top: 14px;
        font-size: 14px;
        line-height: 1.8;
        color: var(--text-soft);
    }

    .overview-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .overview-side {
        background: linear-gradient(180deg, var(--dark-card) 0%, var(--dark-card-soft) 100%);
        border-radius: 24px;
        padding: 22px;
        box-shadow: var(--shadow-md);
        color: var(--dark-card-text);
    }

    .overview-side .side-label {
        font-size: 11px;
        letter-spacing: .10em;
        text-transform: uppercase;
        color: rgba(248,250,252,.62);
        font-weight: 800;
        margin-bottom: 10px;
    }

    .overview-side .side-value {
        font-size: 40px;
        line-height: 1;
        font-weight: 820;
        letter-spacing: -0.05em;
        margin: 0;
    }

    .overview-side .side-note {
        margin-top: 12px;
        font-size: 13px;
        line-height: 1.75;
        color: rgba(248,250,252,.74);
    }

    .overview-metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 18px;
    }

    .overview-mini {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 14px 14px 12px;
    }

    .overview-mini-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(248,250,252,.56);
        font-weight: 800;
        margin-bottom: 8px;
    }

    .overview-mini-value {
        font-size: 26px;
        color: #fff;
        font-weight: 780;
        line-height: 1;
    }

    .overview-mini-note {
        margin-top: 8px;
        font-size: 12px;
        color: rgba(248,250,252,.66);
        line-height: 1.5;
    }

    .detail-top {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 400px);
        gap: 16px;
        margin-bottom: 18px;
    }

    .detail-hero {
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow-xs);
    }

    .detail-kicker {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .10em;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 12px;
    }

    .detail-course-name {
        margin: 0;
        font-size: 30px;
        font-weight: 780;
        line-height: 1.2;
        color: var(--text);
        letter-spacing: -0.04em;
    }

    .detail-course-desc {
        margin-top: 14px;
        font-size: 14px;
        color: var(--text-soft);
        line-height: 1.8;
        max-width: 760px;
    }

    .detail-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
    }

    .detail-side {
        border-radius: 24px;
        padding: 22px;
        background: linear-gradient(180deg, #111827 0%, #1f2937 100%);
        color: #fff;
        box-shadow: var(--shadow-md);
    }

    .detail-side .side-label {
        font-size: 11px;
        letter-spacing: .10em;
        text-transform: uppercase;
        color: rgba(255,255,255,.62);
        font-weight: 800;
        margin-bottom: 10px;
    }

    .detail-side .side-value {
        font-size: 34px;
        line-height: 1.05;
        font-weight: 820;
        letter-spacing: -0.04em;
        margin: 0;
    }

    .detail-side .side-note {
        margin-top: 12px;
        font-size: 13px;
        line-height: 1.75;
        color: rgba(255,255,255,.74);
    }

    .detail-side .side-group {
        margin-top: 18px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .detail-side .side-mini {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 12px 12px 11px;
    }

    .detail-side .side-mini .mini-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(255,255,255,.56);
        font-weight: 800;
        margin-bottom: 6px;
    }

    .detail-side .side-mini .mini-value {
        font-size: 18px;
        color: #fff;
        font-weight: 760;
    }

    .info-section {
        margin-top: 20px;
    }

    .info-title {
        margin: 0 0 12px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: .10em;
        color: var(--text-muted);
        font-weight: 800;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .info-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 16px;
        box-shadow: var(--shadow-xs);
        transition: border-color var(--transition), box-shadow var(--transition);
    }

    .info-card:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-sm);
    }

    .info-card.wide {
        grid-column: 1 / -1;
    }

    .info-label {
        margin-bottom: 8px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-muted);
    }

    .info-value {
        font-size: 15px;
        line-height: 1.65;
        color: var(--text);
        font-weight: 700;
        word-break: break-word;
    }

    .info-value.soft {
        font-weight: 600;
        color: var(--text-soft);
    }

    .result-summary-grid {
        display: grid;
        grid-template-columns: 1.1fr repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 14px;
    }

    .result-box {
        border: 1px solid var(--border);
        border-radius: 20px;
        background: #fff;
        padding: 18px;
        box-shadow: var(--shadow-xs);
        transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }

    .result-box:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
        border-color: var(--border-strong);
    }

    .result-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-muted);
        font-weight: 800;
        margin-bottom: 12px;
    }

    .result-state {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 800;
    }

    .result-state.pass {
        background: var(--success-bg);
        color: var(--success-text);
        border: 1px solid #dcfce7;
    }

    .result-state.fail {
        background: #f8fafc;
        color: var(--text-soft);
        border: 1px solid var(--border);
    }

    .dialog-loading {
        display: none;
        padding-top: 4px;
    }

    .toast-box {
        position: fixed;
        right: 24px;
        top: 24px;
        z-index: 1200;
        display: none;
        padding: 14px 16px;
        border-radius: 14px;
        background: #111827;
        color: #fff;
        box-shadow: 0 16px 36px rgba(15, 23, 42, .20);
        animation: toastIn .22s ease;
        max-width: 380px;
    }

    @@keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes popIn {
        from {
            opacity: 0;
            transform: translateY(16px) scale(.985);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(-8px) scale(.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@media (max-width: 1200px) {
        .metric-strip,
        .detail-top,
        .overview-content,
        .result-summary-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .my-course-page {
            padding: 18px 12px;
        }

        .page-title,
        .dialog-title,
        .detail-course-name,
        .overview-title {
            font-size: 26px;
        }

        .section-shell,
        .dialog-panel {
            border-radius: 22px;
        }

        .section-head,
        .toolbar-row,
        .metric-strip,
        .table-wrap,
        .loading-shell,
        .dialog-head,
        .dialog-body {
            padding-left: 16px;
            padding-right: 16px;
        }

        .info-grid,
        .detail-side .side-group,
        .overview-metrics {
            grid-template-columns: 1fr;
        }

        .dialog-backdrop {
            padding: 72px 10px 10px;
        }

        .dialog-panel {
            width: min(100%, calc(100vw - 12px));
            max-height: calc(100vh - 84px);
            border-radius: 22px;
        }
    }
</style>


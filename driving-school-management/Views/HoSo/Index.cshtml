@using System.Text.Json
@using driving_school_management.Models.DTOs
@model MyHoSoPageDto

@{
    ViewData["Title"] = "Hồ sơ của tôi";
    var detailJson = JsonSerializer.Serialize(Model?.Details ?? new List<HoSoDetailDto>());
    var missingFieldsJson = JsonSerializer.Serialize(Model?.MissingFields ?? new List<string>());
    var canCreateHoSo = Model?.CanCreateHoSo ?? false;
    var hocVienAvatarUrl = string.IsNullOrWhiteSpace(Model?.HocVienAvatarUrl)
        ? Url.Content("~/images/avatar/default.png")
        : Model!.HocVienAvatarUrl;
}

<style>
    :root {
        --bg: #f6f8fb;
        --surface: rgba(255,255,255,.96);
        --surface-soft: #fbfcfe;
        --border: #e7ebf2;
        --border-strong: #d9e0ea;
        --text-main: #0f172a;
        --text-sub: #667085;
        --text-soft: #94a3b8;
        --success: #15803d;
        --success-bg: #edfdf3;
        --danger: #b42318;
        --danger-bg: #fef3f2;
        --shadow-sm: 0 10px 30px rgba(15,23,42,.04);
        --shadow-md: 0 18px 40px rgba(15,23,42,.08);
        --app-header-height: 96px;
    }

    .page {
        padding: 42px 40px 56px;
        background: var(--bg);
        min-height: calc(100vh - 72px);
    }

    .page-shell {
        max-width: 1360px;
        margin: 0 auto;
    }

    .hero {
        display: grid;
        grid-template-columns: 1.4fr .9fr;
        gap: 24px;
        margin-bottom: 30px;
    }

    .hero-main,
    .metric-card,
    .card,
    .hero-panel,
    .side-panel,
    .detail-block {
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
    }

    .hero-main {
        border-radius: 28px;
        padding: 30px 32px;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid var(--border);
        font-size: 12px;
        font-weight: 600;
        color: var(--text-sub);
    }

    .hero-title {
        margin: 16px 0 10px;
        font-size: 40px;
        line-height: 1.1;
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -.03em;
    }

    .hero-subtitle,
    .section-note,
    .metric-note,
    .meta {
        color: var(--text-sub);
    }

    .hero-subtitle {
        max-width: 760px;
        font-size: 15px;
        line-height: 1.7;
    }

    .hero-side {
        display: grid;
        grid-template-rows: 1fr 1fr;
        gap: 24px;
    }

    .metric-card {
        border-radius: 24px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .metric-label,
    .label {
        color: var(--text-soft);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: .02em;
        text-transform: uppercase;
    }

    .metric-value {
        font-size: 30px;
        line-height: 1;
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -.03em;
        margin-top: 10px;
    }

    .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 18px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-main);
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
    }

    .card {
        border-radius: 22px;
        padding: 22px;
        min-height: 280px;
        cursor: pointer;
        transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
        border-color: var(--border-strong);
    }

    .card-top {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .avatar {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .name {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.2;
    }

    .meta {
        font-size: 14px;
        line-height: 1.45;
    }

    .chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid var(--border);
        background: #fafbfd;
        color: var(--text-sub);
    }

    .chip-status-valid {
        color: var(--success);
        background: var(--success-bg);
        border-color: rgba(21,128,61,.14);
    }

    .chip-status-expired {
        color: var(--danger);
        background: var(--danger-bg);
        border-color: rgba(180,35,24,.14);
    }

    .info {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px 18px;
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid var(--border);
    }

    .info-block,
    .field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .value {
        font-size: 15px;
        font-weight: 650;
        color: var(--text-main);
        line-height: 1.4;
        word-break: break-word;
    }

    .value-sm {
        font-size: 14px;
        font-weight: 600;
    }

    .footer-row {
        margin-top: 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .expire {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .expire.valid {
        color: var(--success);
        background: var(--success-bg);
    }

    .expire.expired {
        color: var(--danger);
        background: var(--danger-bg);
    }

    .view-more {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-main);
    }

    .pagination {
        margin-top: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .page-btn {
        min-width: 42px;
        height: 42px;
        padding: 0 14px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,.96);
        color: var(--text-main);
        cursor: pointer;
        font-weight: 700;
    }

    .page-indicator {
        min-width: 110px;
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-sub);
    }

    .empty-state {
        background: var(--surface);
        border: 1px dashed var(--border-strong);
        border-radius: 24px;
        padding: 48px 24px;
        text-align: center;
        color: var(--text-sub);
    }

    /* IMPORTANT: renamed classes, no .modal */
    .hoso-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .34);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: none;
        align-items: flex-start;
        justify-content: center;
        padding: calc(var(--app-header-height) + 20px) 24px 24px;
        z-index: 3000;
        overflow-y: auto;
    }

    .hoso-modal-overlay.show {
        display: flex;
    }

    .hoso-modal-panel {
        width: min(920px, 100%);
        max-height: calc(100vh - var(--app-header-height) - 44px);
        margin: 0 auto;
        overflow: auto;
        background: rgba(255,255,255,.98);
        border: 1px solid rgba(231,235,242,.9);
        border-radius: 26px;
        box-shadow: 0 24px 70px rgba(15,23,42,.14);
        animation: hosoModalFade .24s ease;
    }

    @@keyframes hosoModalFade {
        from {
            opacity: 0;
            transform: translateY(8px) scale(.985);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .hoso-modal-header {
        padding: 18px 22px 16px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 16px;
        position: sticky;
        top: 0;
        background: rgba(255,255,255,.97);
        z-index: 5;
    }

    .hoso-modal-title-wrap {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .hoso-modal-avatar {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        object-fit: cover;
        border: 1px solid var(--border);
        background: #fff;
    }

    .hoso-modal-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-main);
    }

    .hoso-modal-subtitle {
        margin-top: 3px;
        color: var(--text-sub);
        font-size: 13px;
        line-height: 1.45;
    }

    .hoso-modal-close {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-main);
        font-size: 20px;
        cursor: pointer;
        flex-shrink: 0;
    }

    .hoso-modal-body {
        padding: 20px 22px 24px;
    }

    .modal-hero {
        display: grid;
        grid-template-columns: 1.3fr .9fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    .hero-panel,
    .side-panel,
    .detail-block {
        border-radius: 18px;
        padding: 18px;
    }

    .hero-panel-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 18px;
    }

    .hero-panel-name {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-main);
    }

    .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .badge-soft {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        background: #fff;
        border: 1px solid var(--border);
        color: var(--text-sub);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .detail-block-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 12px;
    }

    .field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px 16px;
    }

    .field-grid.single {
        grid-template-columns: 1fr;
    }

    .field.full {
        grid-column: 1 / -1;
    }

    .gallery {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .gallery-item {
        display: block;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: #fff;
        aspect-ratio: 16 / 10;
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .gallery-empty {
        color: var(--text-sub);
        font-size: 14px;
    }

    @@media (max-width: 1199px) {
        .hero, .modal-hero, .detail-grid {
            grid-template-columns: 1fr;
        }

        .grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767px) {
        .page {
            padding: 24px 16px 32px;
        }

        .hero-title {
            font-size: 32px;
        }

        .grid, .field-grid, .gallery, .info {
            grid-template-columns: 1fr;
        }

        .hoso-modal-overlay {
            padding: calc(var(--app-header-height) + 12px) 12px 12px;
        }

        .hoso-modal-panel {
            width: 100%;
            max-height: calc(100vh - var(--app-header-height) - 24px);
            border-radius: 20px;
        }
    }

    .metric-card-highlight {
        background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,250,252,.98));
    }

    .metric-owner {
        color: var(--text-main);
        font-weight: 700;
    }

    .action-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-ui {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-main);
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        transition: all .2s ease;
        box-shadow: var(--shadow-sm);
    }

    .btn-ui:hover {
        text-decoration: none;
        color: var(--text-main);
        transform: translateY(-1px);
        border-color: var(--border-strong);
    }

    .btn-ui-primary {
        background: var(--text-main);
        color: #fff;
        border-color: var(--text-main);
    }

    .btn-ui-primary:hover {
        color: #fff;
        box-shadow: var(--shadow-md);
    }

    .btn-ui-secondary {
        background: #fff;
        color: var(--text-main);
    }

    .btn-ui-soft {
        background: #f8fafc;
        color: var(--text-main);
    }

    .btn-ui-disabled,
    .btn-ui:disabled {
        opacity: .5;
        cursor: not-allowed;
        pointer-events: none;
        box-shadow: none;
    }

    .card-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .card-link-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 36px;
        padding: 0 12px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-main);
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        transition: all .2s ease;
    }

    .card-link-btn:hover {
        text-decoration: none;
        color: var(--text-main);
        border-color: var(--border-strong);
        transform: translateY(-1px);
    }

    .card-link-btn.disabled {
        opacity: .48;
        pointer-events: none;
    }

    .edit-note {
        font-size: 12px;
        color: var(--text-sub);
        line-height: 1.5;
    }

    .modal-action-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .modal-action-left,
    .modal-action-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .status-note {
        font-size: 12px;
        color: var(--text-sub);
    }

    .create-check-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .42);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: none;
        align-items: flex-start;
        justify-content: center;
        padding: calc(var(--app-header-height) + 20px) 24px 24px;
        z-index: 3500;
        overflow-y: auto;
    }

    .create-check-modal-overlay.show {
        display: flex;
    }

    .create-check-modal {
        width: min(760px, 100%);
        background: rgba(255,255,255,.98);
        border: 1px solid rgba(231,235,242,.9);
        border-radius: 28px;
        box-shadow: 0 24px 70px rgba(15,23,42,.14);
        overflow: hidden;
        animation: createCheckFade .24s ease;
    }

    @@keyframes createCheckFade {
        from {
            opacity: 0;
            transform: translateY(8px) scale(.985);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .create-check-header {
        padding: 22px 24px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 14px;
    }

    .create-check-title-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .create-check-avatar {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        object-fit: cover;
        border: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .create-check-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.2;
        letter-spacing: -.02em;
    }

    .create-check-subtitle {
        margin-top: 4px;
        color: var(--text-sub);
        font-size: 14px;
        line-height: 1.6;
    }

    .create-check-close {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-main);
        font-size: 20px;
        cursor: pointer;
        flex-shrink: 0;
    }

    .create-check-body {
        padding: 22px 24px 24px;
        display: grid;
        gap: 18px;
    }

    .create-check-panel {
        background: var(--surface-soft);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 18px;
    }

    .create-check-panel-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 10px;
    }

    .create-check-note {
        font-size: 14px;
        color: var(--text-sub);
        line-height: 1.65;
    }

    .create-check-list {
        margin: 0;
        padding-left: 18px;
        display: grid;
        gap: 8px;
        color: var(--text-main);
        font-size: 14px;
        line-height: 1.6;
    }

    .create-check-list li::marker {
        color: var(--danger);
    }

    .create-check-alert-ok {
        color: var(--success);
        background: var(--success-bg);
        border: 1px solid rgba(21,128,61,.14);
        border-radius: 16px;
        padding: 14px 16px;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.6;
    }

    .create-check-alert-missing {
        color: var(--danger);
        background: var(--danger-bg);
        border: 1px solid rgba(180,35,24,.14);
        border-radius: 16px;
        padding: 14px 16px;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.6;
    }

    .create-check-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        padding-top: 4px;
    }

    .create-check-actions-left,
    .create-check-actions-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }
</style>

<div class="page">
    <div class="page-shell">
        @{
            var total = Model?.Cards?.Count ?? 0;
            var validCount = Model?.Cards?.Count(x => x.SoNgayConLai > 0) ?? 0;
            var expiredCount = Model?.Cards?.Count(x => x.SoNgayConLai <= 0) ?? 0;
            var accountName = Model?.Cards?.FirstOrDefault()?.HoTen ?? "Bạn";
        }

        <div class="hero">
            <div class="hero-main">
                <div class="eyebrow">Hồ sơ cá nhân</div>
                <div class="hero-title">Hồ sơ của tôi</div>
                <div class="hero-subtitle">
                    Theo dõi trạng thái hồ sơ, thời hạn hiệu lực và toàn bộ thông tin chi tiết liên quan đến hồ sơ đăng ký học và khám sức khỏe.
                </div>
            </div>

            <div class="hero-side">
                <div class="metric-card metric-card-highlight">
                    <div class="metric-label">Tổng hồ sơ</div>
                    <div class="metric-value">@total</div>
                    <div class="metric-note">
                        Toàn bộ hồ sơ thuộc tài khoản <strong class="metric-owner">@accountName</strong>
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-label">Còn hiệu lực / Hết hạn</div>
                    <div class="metric-value">@validCount / @expiredCount</div>
                    <div class="metric-note">
                        Hồ sơ của <strong class="metric-owner">@accountName</strong> được phân loại theo thời hạn hiện tại
                    </div>
                </div>
            </div>
        </div>

        <div class="section-head">
            <div>
                <div class="section-title">Danh sách hồ sơ</div>
                <div class="section-note">Mỗi hồ sơ hiển thị thông tin trọng tâm, nhấn để xem chi tiết đầy đủ.</div>
            </div>

            <div class="action-bar">
                <button type="button" class="btn-ui btn-ui-primary" onclick="openCreateCheckModal()">+ Tạo hồ sơ</button>
            </div>
        </div>

        @if (Model == null || Model.Cards == null || Model.Cards.Count == 0)
        {
            <div class="empty-state">Chưa có hồ sơ nào.</div>
        }
        else
        {
            <div class="grid" id="grid">
                @foreach (var item in Model.Cards)
                {
                    var avatar = string.IsNullOrWhiteSpace(item.AvatarUrl)
                        ? Url.Content("~/images/avatar/default.png")
                        : item.AvatarUrl;

                    var isExpired = item.SoNgayConLai <= 0;
                    var canEdit = !isExpired &&
                                  (string.Equals(item.TrangThai, "Đang xử lý", StringComparison.OrdinalIgnoreCase)
                                   || string.Equals(item.TrangThai, "Bị loại", StringComparison.OrdinalIgnoreCase));

                    var expireText = isExpired
                        ? "Hết hạn"
                        : (item.SoThangConLai > 0 ? $"Còn {item.SoThangConLai} tháng" : $"Còn {item.SoNgayConLai} ngày");

                    <div class="card" onclick="openDetail(@item.HoSoId)">
                        <div>
                            <div class="card-top">
                                <img src="@avatar" class="avatar" alt="avatar" />
                                <div>
                                    <div class="name">@item.HoTen</div>
                                    <div class="meta">@item.TenHoSo</div>
                                </div>
                            </div>

                            <div class="chips">
                                <span class="chip">@item.TenHang</span>
                                <span class="chip @(isExpired ? "chip-status-expired" : "chip-status-valid")">
                                    @(isExpired ? "Đã hết hạn" : "Đang hiệu lực")
                                </span>
                            </div>

                            <div class="info">
                                <div class="info-block">
                                    <div class="label">Ngày đăng ký</div>
                                    <div class="value value-sm">@item.NgayDangKy.ToString("dd/MM/yyyy")</div>
                                </div>

                                <div class="info-block">
                                    <div class="label">Trạng thái</div>
                                    <div class="value value-sm">@item.TrangThai</div>
                                </div>
                            </div>

                            <div class="card-actions" onclick="event.stopPropagation()">
                                <a href="/HoSo/Edit/@item.HoSoId"
                                   class="card-link-btn @(canEdit ? "" : "disabled")">
                                    Sửa hồ sơ
                                </a>

                                @if (!canEdit)
                                {
                                    <div class="edit-note">
                                        Chỉ sửa được khi còn hạn và trạng thái là Đang xử lý hoặc Bị loại.
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="footer-row">
                            <div class="expire @(isExpired ? "expired" : "valid")">@expireText</div>
                            <div class="view-more">Xem chi tiết →</div>
                        </div>
                    </div>
                }
            </div>

            <div class="pagination">
                <button type="button" class="page-btn" id="prevBtn" onclick="prevPage()">‹</button>
                <div class="page-indicator" id="pageIndicator"></div>
                <button type="button" class="page-btn" id="nextBtn" onclick="nextPage()">›</button>
            </div>
        }
    </div>
</div>

<div id="hosoModalOverlay" class="hoso-modal-overlay">
    <div class="hoso-modal-panel">
        <div class="hoso-modal-header">
            <div class="hoso-modal-title-wrap">
                <img id="hosoModalAvatar" class="hoso-modal-avatar" src="@Url.Content("~/images/avatar/default.png")" alt="avatar" />
                <div>
                    <div class="hoso-modal-title" id="hosoModalTitle">Chi tiết hồ sơ</div>
                    <div class="hoso-modal-subtitle" id="hosoModalSubtitle"></div>
                </div>
            </div>

            <button type="button" class="hoso-modal-close" onclick="closeModal()">×</button>
        </div>

        <div class="hoso-modal-body" id="hosoModalBody"></div>
    </div>
</div>

<div id="createCheckOverlay" class="create-check-modal-overlay">
    <div class="create-check-modal">
        <div class="create-check-header">
            <div class="create-check-title-wrap">
                <img src="@hocVienAvatarUrl" class="create-check-avatar" alt="avatar học viên" />
                <div>
                    <div class="create-check-title">Tạo hồ sơ mới</div>
                    <div class="create-check-subtitle">
                        Kiểm tra điều kiện trước khi chuyển sang màn hình tạo hồ sơ.
                    </div>
                </div>
            </div>

            <button type="button" class="create-check-close" onclick="closeCreateCheckModal()">×</button>
        </div>

        <div class="create-check-body" id="createCheckBody"></div>
    </div>
</div>

<script>
const details = @Html.Raw(detailJson);
const cards = Array.from(document.querySelectorAll('#grid .card'));
const perPage = 9;
let currentPage = 1;
const totalPages = Math.max(1, Math.ceil(cards.length / perPage));

function renderPage() {
    const start = (currentPage - 1) * perPage;
    const end = start + perPage;

    cards.forEach((card, index) => {
        card.style.display = (index >= start && index < end) ? 'flex' : 'none';
    });

    const indicator = document.getElementById('pageIndicator');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');

    if (indicator) indicator.textContent = `Trang ${currentPage} / ${totalPages}`;
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
}

function prevPage() {
    if (currentPage > 1) {
        currentPage--;
        renderPage();
    }
}

function nextPage() {
    if (currentPage < totalPages) {
        currentPage++;
        renderPage();
    }
}

function formatDate(value) {
    if (!value) return '';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    const d = String(date.getDate()).padStart(2, '0');
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const y = date.getFullYear();
    return `${d}/${m}/${y}`;
}

function getExpireHtml(item) {
    const soNgay = item.soNgayConLai ?? item.SoNgayConLai ?? 0;
    const soThang = item.soThangConLai ?? item.SoThangConLai ?? 0;

    if (soNgay <= 0) {
        return `<span class="badge-soft" style="color:#b42318;background:#fef3f2;border-color:rgba(180,35,24,.14);">Đã hết hạn</span>`;
    }

    if (soThang > 0) {
        return `<span class="badge-soft" style="color:#15803d;background:#edfdf3;border-color:rgba(21,128,61,.14);">Còn ${soThang} tháng</span>`;
    }

    return `<span class="badge-soft" style="color:#15803d;background:#edfdf3;border-color:rgba(21,128,61,.14);">Còn ${soNgay} ngày</span>`;
}

function val(v) {
    if (v === null || v === undefined || v === '') return '—';
    return v;
}

function normalizeText(v) {
    if (v === null || v === undefined) return '';
    return String(v).trim().toLowerCase();
}

function canEditHoSo(item) {
    const soNgay = item.soNgayConLai ?? item.SoNgayConLai ?? 0;
    const trangThai = normalizeText(item.trangThai ?? item.TrangThai);

    const conHan = soNgay > 0;
    const dungTrangThai = trangThai === 'đang xử lý' || trangThai === 'bị loại';

    return conHan && dungTrangThai;
}

function openDetail(id) {
    const item = details.find(x => (x.hoSoId ?? x.HoSoId) === id);
    if (!item) return;

    const avatar = item.avatarUrl || item.AvatarUrl || '@Url.Content("~/images/avatar/default.png")';
    const title = item.hoTen || item.HoTen || 'Chi tiết hồ sơ';
    const subtitle = `${val(item.tenHoSo || item.TenHoSo)} • ${val(item.tenHang || item.TenHang)}`;
    const canEdit = canEditHoSo(item);
    const editButtonHtml = canEdit
        ? `<a href="/HoSo/Edit/${item.hoSoId ?? item.HoSoId}" class="btn-ui btn-ui-secondary">Sửa hồ sơ</a>`
        : `<button type="button" class="btn-ui btn-ui-disabled">Sửa hồ sơ</button>`;

    const createButtonHtml = `<button type="button" class="btn-ui btn-ui-primary" onclick="closeModal(); openCreateCheckModal();">+ Tạo hồ sơ</button>`;

    document.getElementById('hosoModalAvatar').src = avatar;
    document.getElementById('hosoModalTitle').textContent = title;
    document.getElementById('hosoModalSubtitle').textContent = subtitle;

    const images = item.images || item.Images || [];
    const galleryHtml = images.length > 0
        ? `<div class="gallery">
                ${images.map(img => `<a class="gallery-item" href="${img}" target="_blank"><img src="${img}" alt="Ảnh khám sức khỏe" /></a>`).join('')}
           </div>`
        : `<div class="gallery-empty">Không có ảnh khám sức khỏe.</div>`;

    document.getElementById('hosoModalBody').innerHTML = `
        <div class="modal-action-row">
            <div class="modal-action-left">
                ${editButtonHtml}
                <div class="status-note">
                    ${canEdit ? 'Hồ sơ này hiện có thể chỉnh sửa.' : 'Chỉ sửa được khi hồ sơ còn hạn và trạng thái là Đang xử lý hoặc Bị loại.'}
                </div>
            </div>

            <div class="modal-action-right">
                ${createButtonHtml}
            </div>
        </div>

        <div class="modal-hero">
            <div class="hero-panel">
                <div class="hero-panel-title">
                    <div class="hero-panel-name">${title}</div>
                    <div class="badges">
                        <span class="badge-soft">${val(item.trangThai || item.TrangThai)}</span>
                        ${getExpireHtml(item)}
                    </div>
                </div>

                <div class="field-grid">
                    <div class="field">
                        <div class="label">Tên hồ sơ</div>
                        <div class="value">${val(item.tenHoSo || item.TenHoSo)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Loại hồ sơ</div>
                        <div class="value">${val(item.loaiHoSo || item.LoaiHoSo)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Hạng GPLX</div>
                        <div class="value">${val(item.tenHang || item.TenHang)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Ngày đăng ký</div>
                        <div class="value">${formatDate(item.ngayDangKy || item.NgayDangKy)}</div>
                    </div>
                    <div class="field full">
                        <div class="label">Ghi chú hồ sơ</div>
                        <div class="value value-sm">${val(item.ghiChu || item.GhiChu)}</div>
                    </div>
                </div>
            </div>

            <div class="side-panel">
                <div class="detail-block-title">Tình trạng hiệu lực</div>
                <div class="field-grid single">
                    <div class="field">
                        <div class="label">Hiệu lực giấy khám</div>
                        <div class="value">${val(item.hieuLuc || item.HieuLuc)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Thời hạn giấy khám</div>
                        <div class="value">${formatDate(item.thoiHan || item.ThoiHan)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Thời hạn còn lại</div>
                        <div class="value">${(item.soNgayConLai ?? item.SoNgayConLai ?? 0) <= 0
                            ? 'Đã hết hạn'
                            : ((item.soThangConLai ?? item.SoThangConLai ?? 0) > 0
                                ? `Còn ${item.soThangConLai ?? item.SoThangConLai} tháng`
                                : `Còn ${item.soNgayConLai ?? item.SoNgayConLai} ngày`)}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-block">
                <div class="detail-block-title">Thông tin học viên</div>
                <div class="field-grid">
                    <div class="field">
                        <div class="label">Họ tên</div>
                        <div class="value">${val(item.hoTen || item.HoTen)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Số CMND/CCCD</div>
                        <div class="value">${val(item.soCmndCccd || item.SoCmndCccd)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Ngày sinh</div>
                        <div class="value">${formatDate(item.namSinh || item.NamSinh)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Giới tính</div>
                        <div class="value">${val(item.gioiTinh || item.GioiTinh)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Số điện thoại</div>
                        <div class="value">${val(item.sdt || item.Sdt)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Email</div>
                        <div class="value">${val(item.email || item.Email)}</div>
                    </div>
                </div>
            </div>

            <div class="detail-block">
                <div class="detail-block-title">Thông tin khám sức khỏe</div>
                <div class="field-grid">
                    <div class="field">
                        <div class="label">Khám mắt</div>
                        <div class="value">${val(item.khamMat || item.KhamMat)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Huyết áp</div>
                        <div class="value">${val(item.huyetAp || item.HuyetAp)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Chiều cao</div>
                        <div class="value">${val(item.chieuCao || item.ChieuCao)}</div>
                    </div>
                    <div class="field">
                        <div class="label">Cân nặng</div>
                        <div class="value">${val(item.canNang || item.CanNang)}</div>
                    </div>
                </div>
            </div>

            <div class="detail-block" style="grid-column: 1 / -1;">
                <div class="detail-block-title">Ảnh giấy khám sức khỏe</div>
                ${galleryHtml}
            </div>
        </div>
    `;

    document.getElementById('hosoModalOverlay').classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('hosoModalOverlay').classList.remove('show');
    document.body.style.overflow = '';
}

document.getElementById('hosoModalOverlay').addEventListener('click', function (e) {
    if (e.target === this) {
        closeModal();
    }
});

document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
        closeModal();
    }
});

if (cards.length > 0) {
    renderPage();
}

const createCheckCanCreate = @Html.Raw(JsonSerializer.Serialize(canCreateHoSo));
const createCheckMissingFields = @Html.Raw(missingFieldsJson);
const createCheckAvatarUrl = @Html.Raw(JsonSerializer.Serialize(hocVienAvatarUrl));

function openCreateCheckModal() {
    const body = document.getElementById('createCheckBody');

    if (createCheckCanCreate) {
        body.innerHTML = `
            <div class="create-check-alert-ok">
                Hồ sơ học viên đã đủ điều kiện để tạo hồ sơ mới.
            </div>

            <div class="create-check-panel">
                <div class="create-check-panel-title">Tải mẫu giấy khám sức khỏe</div>
                <div class="create-check-note">
                    Học viên tải mẫu giấy khám sức khỏe mới nhất, mang theo khi đi khám và sau khi có kết quả thì chụp ảnh rõ nét để tải lên làm minh chứng.
                </div>
            </div>

            <div class="create-check-panel">
                <div class="create-check-panel-title">Ảnh thẻ sẽ được sử dụng</div>
                <div class="create-check-note">
                    Ảnh thẻ hiện tại của học viên sẽ được dùng làm <strong>ảnh chính</strong> và sẽ được lưu vào <strong>Phiếu khám sức khỏe.URLANH</strong> khi tạo hồ sơ.
                </div>
            </div>

            <div class="create-check-actions">
                <div class="create-check-actions-left">
                    <a href="/resources/mau-kham-suc-khoe-lai-xe.doc" class="btn-ui btn-ui-soft" download>Tải mẫu giấy khám</a>
                </div>

                <div class="create-check-actions-right">
                    <button type="button" class="btn-ui btn-ui-secondary" onclick="closeCreateCheckModal()">Đóng</button>
                    <a href="/HoSo/Create" class="btn-ui btn-ui-primary">Tiếp tục</a>
                </div>
            </div>
        `;
    } else {
        const missingHtml = createCheckMissingFields.length > 0
            ? `<ul class="create-check-list">${createCheckMissingFields.map(x => `<li>${x}</li>`).join('')}</ul>`
            : `<div class="create-check-note">Không đủ dữ liệu để xác minh.</div>`;

        body.innerHTML = `
            <div class="create-check-alert-missing">
                Học viên chưa đủ điều kiện để tạo hồ sơ mới. Cần bổ sung đầy đủ thông tin bắt buộc trong hồ sơ học viên.
            </div>

            <div class="create-check-panel">
                <div class="create-check-panel-title">Các thông tin còn thiếu</div>
                ${missingHtml}
            </div>

            <div class="create-check-panel">
                <div class="create-check-panel-title">Thông tin bắt buộc</div>
                <div class="create-check-note">
                    Cần có đầy đủ: CCCD, số điện thoại, ảnh thẻ, giới tính, họ tên và email.
                </div>
            </div>

            <div class="create-check-actions">
                <div class="create-check-actions-left"></div>

                <div class="create-check-actions-right">
                    <button type="button" class="btn-ui btn-ui-secondary" onclick="closeCreateCheckModal()">Đóng</button>
                </div>
            </div>
        `;
    }

    document.getElementById('createCheckOverlay').classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeCreateCheckModal() {
    document.getElementById('createCheckOverlay').classList.remove('show');

    if (!document.getElementById('hosoModalOverlay').classList.contains('show')) {
        document.body.style.overflow = '';
    }
}

document.getElementById('createCheckOverlay').addEventListener('click', function (e) {
    if (e.target === this) {
        closeCreateCheckModal();
    }
});

document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && document.getElementById('createCheckOverlay').classList.contains('show')) {
        closeCreateCheckModal();
    }
});

</script>
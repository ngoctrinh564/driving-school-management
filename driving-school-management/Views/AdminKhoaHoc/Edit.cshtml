@model driving_school_management.ViewModels.KhoaHocFormVM

@{
    ViewData["Title"] = "Chỉnh sửa khóa học";
}

<section class="content">
    <div class="container-fluid admin-form-page">

        <div class="page-header-card mb-4">
            <div>
                <div class="page-caption">Quản lý khóa học</div>
                <h3 class="page-title mb-1">Chỉnh sửa khóa học</h3>
                <div class="page-subtitle">Cập nhật thông tin khóa học.</div>
            </div>
        </div>

        <div class="card admin-card border-0">
            <div class="card-body p-3 p-lg-4">

                <form asp-action="Edit" method="post" class="row g-3">

                    <input asp-for="KhoaHocId" type="hidden" />

                    <div class="col-md-6">
                        <label class="form-label admin-label">Tên khóa học</label>
                        <input asp-for="TenKhoaHoc" class="form-control admin-input" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label admin-label">Hạng GPLX</label>
                        <select asp-for="HangId" class="form-select admin-select">
                            @foreach (var h in ViewBag.Hangs)
                            {
                                <option value="@h.hangId" selected="@(Model.HangId == h.hangId)">
                                    @h.tenHang
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label admin-label">Ngày bắt đầu</label>
                        <input asp-for="NgayBatDau" type="date" class="form-control admin-input" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label admin-label">Ngày kết thúc</label>
                        <input asp-for="NgayKetThuc" type="date" class="form-control admin-input" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label admin-label">Địa điểm</label>
                        <input asp-for="DiaDiem" class="form-control admin-input" />
                    </div>

                    <div class="col-12 mt-3">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary admin-btn">
                                <i class="fa fa-save"></i> Cập nhật
                            </button>

                            <a asp-action="Index" class="btn btn-light admin-btn">
                                <i class="fa fa-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </div>

                </form>

            </div>
        </div>

    </div>
</section>

<style>
    .admin-form-page {
        font-family: "Segoe UI", Roboto, sans-serif;
    }

    .admin-card {
        border-radius: 20px;
        box-shadow: 0 8px 18px rgba(15,23,42,0.05);
        border: 1px solid rgba(15,23,42,0.08);
    }

    .admin-label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .admin-input,
    .admin-select {
        height: 44px;
        border-radius: 14px;
        border: 1px solid rgba(15,23,42,0.08);
    }

    .admin-btn {
        height: 44px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
</style>
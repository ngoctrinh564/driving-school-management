@model driving_school_management.ViewModels.RegisterVM

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    .register-container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .register-card {
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: none;
        overflow: hidden;
    }

        .register-card .card-body {
            padding: 2.5rem;
        }

    .register-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .register-header h4 {
            font-weight: 600;
            color: #198754;
            margin-bottom: 0.5rem;
        }

        .register-header p {
            color: #5f6368;
            font-size: 0.9rem;
        }

    .form-floating > .form-control {
        border-radius: 8px;
    }

    .btn-register {
        padding: 12px;
        font-weight: 600;
        border-radius: 8px;
        position: relative;
        background-color: #198754;
        border: none;
    }

        .btn-register.loading .btn-text {
            opacity: 0;
        }

        .btn-register.loading .btn-spinner {
            display: block;
        }

    .btn-spinner {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: none;
    }

    .toggle-password {
        border: none;
        background: transparent;
        position: absolute;
        top: 50%;
        right: 10px;
        transform: translateY(-50%);
        z-index: 5;
    }

    .register-links {
        margin-top: 1.5rem;
        text-align: center;
    }

    .field-validation-error {
        color: red;
        font-size: 14px;
    }

    .input-validation-error {
        border-color: red;
    }
</style>

<div class="register-container">
    <div class="col-md-6 col-lg-4 px-3">
        <div class="card register-card">
            <div class="card-body">

                <div class="register-header">
                    <h4><i class="fa fa-user-plus"></i> Đăng ký</h4>
                    <p>Tạo tài khoản mới</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <form id="registerForm" asp-controller="Auth" asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Username" />
                        <label asp-for="Username">Tên đăng nhập</label>
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <label asp-for="Email">Email</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input id="password" asp-for="Password" type="password" class="form-control" placeholder="Password" />
                        <label asp-for="Password">Mật khẩu</label>

                        <button type="button" class="toggle-password" onclick="togglePassword('password','iconPwd1')">
                            <i id="iconPwd1" class="fa fa-eye"></i>
                        </button>

                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input id="confirmPassword" asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                        <label asp-for="ConfirmPassword">Nhập lại mật khẩu</label>

                        <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword','iconPwd2')">
                            <i id="iconPwd2" class="fa fa-eye"></i>
                        </button>

                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div id="pwdMatch" class="mb-3"></div>

                    <button id="btnRegister" type="submit" class="btn btn-register w-100" disabled>
                        <span class="btn-text">Đăng ký</span>
                        <span class="btn-spinner">
                            <span class="spinner-border spinner-border-sm"></span>
                        </span>
                    </button>
                </form>

                <div class="register-links">
                    <p>
                        Đã có tài khoản?
                        <a asp-action="Login" asp-controller="Auth">Đăng nhập</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }

        const form = document.getElementById("registerForm");
        const pwd = document.getElementById("password");
        const confirmPwd = document.getElementById("confirmPassword");
        const match = document.getElementById("pwdMatch");
        const btn = document.getElementById("btnRegister");

        function validate() {
            if (pwd.value.length === 0 || confirmPwd.value.length === 0) {
                match.innerHTML = "";
                btn.disabled = true;
                return;
            }

            if (pwd.value === confirmPwd.value) {
                match.innerHTML = "<span style='color:green'>✔ Mật khẩu khớp</span>";
                btn.disabled = false;
            } else {
                match.innerHTML = "<span style='color:red'>✘ Mật khẩu không khớp</span>";
                btn.disabled = true;
            }
        }

        pwd.addEventListener("input", validate);
        confirmPwd.addEventListener("input", validate);

        form.addEventListener("submit", function (e) {
            if (pwd.value !== confirmPwd.value) {
                e.preventDefault();
                match.innerHTML = "<span style='color:red'>✘ Mật khẩu không khớp</span>";
                btn.disabled = true;
                return;
            }

            btn.classList.add("loading");
            btn.disabled = true;
        });
    </script>
}
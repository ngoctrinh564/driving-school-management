@model driving_school_management.ViewModels.VerifyOtpVM

@{
    ViewData["Title"] = "Xác nhận OTP";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h4 class="mb-3 text-center">Xác nhận OTP</h4>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form asp-action="VerifyOtp" asp-controller="Auth" method="post">
                        <input asp-for="Username" type="hidden" />
                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Password" type="hidden" />
                        <input asp-for="RoleId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="OtpCode" class="form-label">Mã OTP</label>
                            <input asp-for="OtpCode" class="form-control" />
                            <span asp-validation-for="OtpCode" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Xác nhận</button>
                    </form>

                    <div class="mt-3 text-muted text-center">
                        OTP có hiệu lực trong 60 giây
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
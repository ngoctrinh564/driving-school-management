            </div>
        `;
    }

    async function openPaymentDetail(phieuId) {
        const dialog = document.getElementById('detailDialog');
        const content = document.getElementById('dialogContent');
        const loading = document.getElementById('dialogLoading');

        dialog.style.display = 'flex';
        content.innerHTML = '';
        loading.style.display = 'grid';

        try {
            const response = await fetch('/PaymentHistory/GetPaymentHistoryDetail?phieuId=' + phieuId);
            if (!response.ok) {
                throw new Error('Không thể tải chi tiết thanh toán.');
            }

            const d = await response.json();
            loading.style.display = 'none';
            content.innerHTML = buildDialogContent(d);
        } catch (error) {
            loading.style.display = 'none';
            content.innerHTML = '';
            showToast(error.message || 'Đã xảy ra lỗi.');
        }
    }

    document.getElementById('btnCloseDialog').onclick = () => {
        document.getElementById('detailDialog').style.display = 'none';
    };

    document.getElementById('detailDialog').onclick = (e) => {
        if (e.target.id === 'detailDialog') {
            document.getElementById('detailDialog').style.display = 'none';
        }
    };

    loadPaymentHistory();
</script>
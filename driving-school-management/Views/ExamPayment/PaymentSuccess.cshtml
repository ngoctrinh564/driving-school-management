@{
    ViewData["Title"] = "Thanh toán thành công";
}

<style>
    body {
        background: #f4f7fb;
        font-family: "Segoe UI", Roboto, sans-serif;
    }

    .wrapper {
        height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        background: #fff;
        border-radius: 16px;
        padding: 32px;
        text-align: center;
        border: 1px solid rgba(15,23,42,0.08);
        box-shadow: 0 8px 18px rgba(15,23,42,0.05);
        width: 420px;
    }

    .icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(16,185,129,0.1);
        color: #10b981;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        margin: auto;
        margin-bottom: 18px;
    }

    h2 {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    p {
        color: #64748b;
        font-size: 14px;
    }
</style>

<div class="wrapper">
    <div class="card">
        <div class="icon">✔</div>
        <h2>Thanh toán thành công</h2>
        <p>Giao dịch đã được xử lý.</p>
    </div>
</div>
@{
    ViewData["Title"] = "Khóa học";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    body {
        background: #f5f6f8;
        font-family: 'Segoe UI', sans-serif;
    }

    .container-custom {
        max-width: 1400px;
        margin: auto;
        padding: 30px;
    }

    .header-title {
        font-size: 28px;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 25px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    .card-kh {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
    }

    .card-kh:hover {
        transform: translateY(-5px) scale(1.01);
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .badge-status {
        position: absolute;
        top: 16px;
        right: 16px;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        background: #e5e7eb;
    }

    .status-open {
        background: #e0f2fe;
        color: #0369a1;
    }

    .status-learning {
        background: #ecfdf5;
        color: #047857;
    }

    .card-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #111827;
        padding-right: 110px;
    }

    .meta {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .price {
        margin-top: 10px;
        font-weight: 700;
        font-size: 16px;
        color: #111827;
    }

    .btn-detail {
        margin-top: 15px;
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: none;
        background: #111827;
        color: #fff;
        font-weight: 600;
        transition: 0.2s;
    }

    .btn-detail:hover {
        background: #374151;
    }

    .skeleton {
        height: 180px;
        border-radius: 16px;
        background: linear-gradient(90deg, #eee, #f5f5f5, #eee);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
    }

    @@keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.28);
        backdrop-filter: blur(10px);
        display: none;
        align-items: flex-start;
        justify-content: center;
        z-index: 999;
        padding: 96px 24px 24px;
        overflow-y: auto;
    }

    .modal-box {
        background: #ffffff;
        width: min(640px, calc(100vw - 32px));
        border-radius: 20px;
        padding: 22px 22px 18px;
        animation: fadeIn 0.25s ease;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.16);
        border: 1px solid rgba(229, 231, 235, 0.95);
    }

    .modal-header-custom {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .modal-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .modal-title {
        margin: 0;
        font-size: 28px;
        line-height: 1.25;
        font-weight: 600;
        color: #0f172a;
        max-width: 480px;
    }

    .modal-close-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        color: #111827;
        font-size: 22px;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all .2s ease;
        flex-shrink: 0;
        cursor: pointer;
    }

    .modal-close-btn:hover {
        background: #eef2f7;
        border-color: #d1d5db;
    }

    @@keyframes fadeIn {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .modal-footer {
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #eef2f7;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: #0f172a;
        color: white;
        padding: 10px 18px;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        min-width: 140px;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.16);
        transition: all .2s ease;
        cursor: pointer;
    }

    .btn-primary:hover {
        background: #020617;
        transform: translateY(-1px);
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.22);
    }

    .btn-secondary-action {
        background: #f8fafc;
        color: #111827;
        padding: 10px 18px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        font-weight: 600;
        transition: all .2s ease;
        cursor: pointer;
    }

    .btn-secondary-action:hover {
        background: #eef2f7;
        border-color: #d1d5db;
    }

    .btn-disabled {
        background: #d1d5db !important;
        color: #6b7280 !important;
        cursor: not-allowed !important;
        border: none;
        box-shadow: none !important;
        transform: none !important;
    }

    .course-detail-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 200px;
        gap: 16px;
        align-items: start;
    }

    .course-detail-main {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .course-detail-summary {
        font-size: 15px;
        line-height: 1.75;
        color: #374151;
        background: #fafafa;
        border: 1px solid #eef2f7;
        border-radius: 16px;
        padding: 16px 18px;
    }

    .course-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .detail-item {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 12px 14px;
        transition: all .2s ease;
    }

    .detail-item:hover {
        border-color: #d1d5db;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .detail-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 8px;
    }

    .detail-value {
        font-size: 16px;
        font-weight: 600;
        line-height: 1.4;
        color: #111827;
    }

    .course-detail-side {
        background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
        color: #fff;
        border-radius: 16px;
        padding: 16px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .side-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .side-badge-open {
        background: rgba(96, 165, 250, 0.18);
        color: #dbeafe;
    }

    .side-badge-learning {
        background: rgba(52, 211, 153, 0.16);
        color: #d1fae5;
    }

    .side-price-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(255,255,255,0.65);
        margin-bottom: 8px;
    }

    .side-price-value {
        font-size: 24px;
        line-height: 1.2;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .side-note {
        font-size: 13px;
        line-height: 1.65;
        color: rgba(255,255,255,0.76);
    }

    @@media (max-width: 768px) {
        .container-custom {
            padding: 20px 16px;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .modal-box {
            width: min(100%, calc(100vw - 20px));
            padding: 18px;
            border-radius: 18px;
        }

        .modal-title {
            font-size: 22px;
            max-width: 100%;
        }

        .course-detail-layout {
            grid-template-columns: 1fr;
        }

        .course-detail-grid {
            grid-template-columns: 1fr;
        }

        .course-detail-side {
            order: -1;
        }

        .modal-footer {
            justify-content: stretch;
        }

        .modal-footer button {
            width: 100%;
        }
    }
</style>

<div class="container-custom">
    <div class="header-title">Danh sách khóa học</div>

    <div id="loading" class="grid">
        <div class="skeleton"></div>
        <div class="skeleton"></div>
        <div class="skeleton"></div>
    </div>

    <div id="courseList" class="grid" style="display:none;"></div>
</div>

<div id="modal" class="modal-backdrop-custom">
    <div class="modal-box">
        <div class="modal-header-custom">
            <div>
                <div class="modal-eyebrow">Thông tin khóa học</div>
                <h3 id="modalTitle" class="modal-title"></h3>
            </div>
            <button type="button" id="btnCloseModal" class="modal-close-btn" aria-label="Đóng">×</button>
        </div>

        <div id="modalContent"></div>

        <div class="modal-footer">
            <button type="button" id="loginActionBtn" class="btn-secondary-action" style="display:none;"></button>
            <button type="button" id="btnRegister" class="btn-primary">Đăng ký ngay</button>
        </div>
    </div>
</div>

<script>
    let isLoggedIn = @(Context.Session.GetInt32("UserId") != null ? "true" : "false");

    async function loadCourses() {
        const res = await fetch('/KhoaHoc/GetDanhSachKhoaHocDangMo');
        const data = await res.json();

        document.getElementById('loading').style.display = 'none';
        const container = document.getElementById('courseList');
        container.style.display = 'grid';
        container.innerHTML = '';

        data.forEach(c => {
            const isRegisterable = c.trangThai === 'Sắp khai giảng';
            const statusClass = isRegisterable ? 'status-open' : 'status-learning';

            const html = `
                <div class="card-kh">
                    <div class="badge-status ${statusClass}">${c.trangThai}</div>
                    <div class="card-title">${c.tenKhoaHoc}</div>
                    <div class="meta">Hạng: ${c.tenHang}</div>
                    <div class="meta">Bắt đầu: ${new Date(c.ngayBatDau).toLocaleDateString('vi-VN')}</div>
                    <div class="meta">Địa điểm: ${c.diaDiem}</div>
                    <div class="price">${Number(c.hocPhi).toLocaleString('vi-VN')} VNĐ</div>
                    <button type="button" class="btn-detail" onclick="openDetail(${c.khoaHocId})">Xem chi tiết</button>
                </div>
            `;
            container.innerHTML += html;
        });
    }

    async function openDetail(id) {
        const res = await fetch('/KhoaHoc/GetKhoaHocDetail?id=' + id);
        const d = await res.json();

        document.getElementById('modalTitle').innerText = d.tenKhoaHoc;

        const isCourseOpenForRegister = d.trangThai === 'Sắp khai giảng';
        const badgeClass = isCourseOpenForRegister ? 'side-badge side-badge-open' : 'side-badge side-badge-learning';

        document.getElementById('modalContent').innerHTML = `
            <div class="course-detail-layout">
                <div class="course-detail-main">
                    <div class="course-detail-summary">
                        ${d.moTa ?? 'Chưa có mô tả cho khóa học này.'}
                    </div>

                    <div class="course-detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Hạng</div>
                            <div class="detail-value">${d.tenHang ?? ''}</div>
                        </div>

                        <div class="detail-item">
                            <div class="detail-label">Phương tiện</div>
                            <div class="detail-value">${d.loaiPhuongTien ?? ''}</div>
                        </div>

                        <div class="detail-item">
                            <div class="detail-label">Ngày bắt đầu</div>
                            <div class="detail-value">${new Date(d.ngayBatDau).toLocaleDateString('vi-VN')}</div>
                        </div>

                        <div class="detail-item">
                            <div class="detail-label">Ngày kết thúc</div>
                            <div class="detail-value">${new Date(d.ngayKetThuc).toLocaleDateString('vi-VN')}</div>
                        </div>

                        <div class="detail-item">
                            <div class="detail-label">Địa điểm</div>
                            <div class="detail-value">${d.diaDiem ?? ''}</div>
                        </div>

                        <div class="detail-item">
                            <div class="detail-label">Trạng thái</div>
                            <div class="detail-value">${d.trangThai ?? ''}</div>
                        </div>
                    </div>
                </div>

                <div class="course-detail-side">
                    <div class="${badgeClass}">${d.trangThai ?? ''}</div>
                    <div class="side-price-label">Học phí</div>
                    <div class="side-price-value">${Number(d.hocPhi).toLocaleString('vi-VN')} VNĐ</div>
                    <div class="side-note">
                        ${isCourseOpenForRegister
                            ? 'Khóa học hiện đang mở đăng ký. Hoàn tất xác nhận để chuyển sang bước thanh toán.'
                            : 'Khóa học đã bắt đầu, hiện không tiếp nhận đăng ký mới.'}
                    </div>
                </div>
            </div>
        `;

        const btnRegister = document.getElementById('btnRegister');
        const loginActionBtn = document.getElementById('loginActionBtn');

        if (!isLoggedIn) {
            loginActionBtn.style.display = 'inline-flex';
            loginActionBtn.innerText = 'Đăng nhập để đăng ký';
            loginActionBtn.onclick = () => window.location.href = '/Auth/Login';

            btnRegister.style.display = 'none';
            btnRegister.disabled = false;
            btnRegister.classList.remove('btn-disabled');
        }
        else if (!isCourseOpenForRegister) {
            loginActionBtn.style.display = 'none';

            btnRegister.style.display = 'inline-flex';
            btnRegister.innerText = 'Đã bắt đầu - không thể đăng ký';
            btnRegister.disabled = true;
            btnRegister.classList.add('btn-disabled');
            btnRegister.onclick = null;
        }
        else {
            loginActionBtn.style.display = 'none';

            btnRegister.style.display = 'inline-flex';
            btnRegister.innerText = 'Đăng ký ngay';
            btnRegister.disabled = false;
            btnRegister.classList.remove('btn-disabled');
            btnRegister.onclick = () => window.location.href = '/DangKy/Confirm?khoaHocId=' + id;
        }

        document.getElementById('modal').style.display = 'flex';
    }

    document.getElementById('btnCloseModal').onclick = () => {
        document.getElementById('modal').style.display = 'none';
    };

    document.getElementById('modal').onclick = (e) => {
        if (e.target.id === 'modal') {
            document.getElementById('modal').style.display = 'none';
        }
    };

    loadCourses();
</script>
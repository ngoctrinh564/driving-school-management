@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Admin";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";

    var initials = !string.IsNullOrWhiteSpace(username)
        ? string.Join("", username.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper()
        : "AD";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" href="~/images/logo/logo-mini.png" />
    <link rel="apple-touch-icon" href="~/images/logo/logo-mini.png" />

    <title>@pageTitle - Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" rel="stylesheet" />

    <style>
            :root {
                --admin-bg: #f4f7fb;
                --admin-surface: #ffffff;
                --admin-border: rgba(15, 23, 42, 0.08);
                --admin-text: #0f172a;
                --admin-text-soft: #64748b;
                --admin-primary: #2563eb;
                --admin-primary-2: #1d4ed8;
                --admin-accent: #7c3aed;
                --admin-success: #16a34a;
                --admin-danger: #dc2626;
                --sidebar-top: #07152f;
                --sidebar-bottom: #0c1c3f;
                --brand-bg-1: #ffffff;
                --brand-bg-2: #eef4ff;
                --brand-title: #0f172a;
                --brand-subtitle: #64748b;
                --shadow-sm: 0 8px 18px rgba(15, 23, 42, 0.05);
            }

            html {
                font-size: 15px;
            }

            body {
                font-family: "Segoe UI", Roboto, Arial, sans-serif;
                background: var(--admin-bg);
                color: var(--admin-text);
            }

            .wrapper {
                overflow-x: hidden;
            }

            .main-header.navbar {
                min-height: 72px;
                height: 72px;
                padding: 0 1rem;
                background: rgba(255, 255, 255, 0.9);
                border-bottom: 1px solid rgba(255,255,255,.55);
                box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
            }

            .layout-navbar-fixed .main-sidebar {
                top: 72px;
                height: calc(100vh - 72px);
            }

            .main-sidebar {
                background: linear-gradient(180deg, var(--sidebar-top) 0%, var(--sidebar-bottom) 100%) !important;
                border-right: 1px solid rgba(255,255,255,.04);
                transition: width .25s ease, margin-left .25s ease;
            }

            .brand-link {
                height: 72px;
                min-height: 72px;
                padding: .5rem 1rem;
                border-bottom: 1px solid rgba(255,255,255,.08) !important;
                display: flex;
                align-items: center;
                justify-content: flex-start;
                text-decoration: none !important;
                background: linear-gradient(135deg, var(--brand-bg-1), var(--brand-bg-2));
            }

            .brand-wrap {
                display: flex;
                align-items: center;
                gap: .9rem;
                width: 100%;
                min-width: 0;
            }

            .brand-logo-shell {
                width: 48px;
                height: 48px;
                border-radius: 16px;
                background: linear-gradient(135deg, #ffffff, #dbeafe);
                border: 1px solid rgba(37,99,235,.12);
                box-shadow: 0 10px 24px rgba(2, 6, 23, .10), inset 0 0 0 1px rgba(255,255,255,.85);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                .brand-logo-shell img {
                    width: 29px;
                    height: 29px;
                    object-fit: contain;
                    filter: drop-shadow(0 2px 6px rgba(37,99,235,.14));
                }

            .brand-text-wrap {
                display: flex;
                flex-direction: column;
                justify-content: center;
                line-height: 1.05;
                min-width: 0;
            }

            .brand-title {
                color: var(--brand-title);
                font-weight: 900;
                font-size: 1.12rem;
                letter-spacing: .04em;
                white-space: nowrap;
                text-transform: uppercase;
            }

            .brand-subtitle {
                color: var(--brand-subtitle);
                font-size: .76rem;
                margin-top: .28rem;
                white-space: nowrap;
                font-weight: 600;
            }

            .sidebar-collapse .brand-link {
                justify-content: center;
                padding: .5rem;
            }

            .sidebar-collapse .brand-text-wrap {
                display: none;
            }

            .sidebar {
                padding: .6rem .8rem 1rem;
            }

            .admin-user-card {
                display: flex;
                align-items: center;
                gap: .9rem;
                padding: 1rem;
                margin-top: .15rem;
                margin-bottom: .95rem;
                border-radius: 20px;
                background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
                border: 1px solid rgba(255,255,255,.10);
                box-shadow: inset 0 1px 0 rgba(255,255,255,.03), 0 12px 24px rgba(0,0,0,.12);
            }

            .admin-avatar {
                width: 54px;
                height: 54px;
                border-radius: 18px;
                background: linear-gradient(135deg, #2563eb, #7c3aed);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                font-size: 1.1rem;
                flex-shrink: 0;
                box-shadow: 0 14px 28px rgba(37,99,235,.28);
            }

            .admin-user-meta {
                min-width: 0;
            }

            .admin-user-name {
                margin: 0;
                color: #ffffff;
                font-weight: 800;
                font-size: 1rem;
                line-height: 1.2;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .admin-user-role {
                margin-top: .18rem;
                color: rgba(255,255,255,.68);
                font-size: .82rem;
            }

            .menu-section-label {
                color: rgba(255,255,255,.45);
                font-size: .74rem;
                font-weight: 800;
                letter-spacing: .12em;
                text-transform: uppercase;
                padding: 1rem .95rem .55rem;
            }

            .nav-sidebar > .nav-item {
                margin-bottom: .35rem;
            }

            .nav-sidebar .nav-link {
                display: flex;
                align-items: center;
                min-height: 48px;
                padding: .92rem 1rem;
                border-radius: 14px;
                color: rgba(255,255,255,.82);
                font-weight: 600;
                transition: all .22s ease;
            }

                .nav-sidebar .nav-link:hover {
                    background: rgba(255,255,255,.08);
                    color: #fff;
                    transform: translateX(2px);
                }

                .nav-sidebar .nav-link.active {
                    background: linear-gradient(135deg, var(--admin-primary), var(--admin-accent));
                    color: #fff !important;
                    box-shadow: 0 14px 26px rgba(37,99,235,.24);
                }

            .nav-sidebar .nav-icon {
                width: 24px;
                margin-right: .8rem;
                text-align: center;
                font-size: 1rem;
            }

            .sidebar-collapse .admin-user-meta,
            .sidebar-collapse .menu-section-label,
            .sidebar-collapse .nav-sidebar .nav-link p {
                display: none !important;
            }

            .sidebar-collapse .admin-user-card {
                justify-content: center;
                padding: .85rem;
            }

            .sidebar-collapse .nav-sidebar .nav-link {
                justify-content: center;
                padding: .95rem .6rem;
            }

            .sidebar-collapse .nav-sidebar .nav-icon {
                margin-right: 0;
            }

            .content-wrapper {
                background: radial-gradient(circle at top right, rgba(124,58,237,.06), transparent 22%), radial-gradient(circle at top left, rgba(37,99,235,.08), transparent 22%), var(--admin-bg);
                min-height: calc(100vh - 72px);
                padding-bottom: .5rem;
            }

            .content-header {
                padding: .9rem .95rem 0;
            }

            .content {
                padding: .85rem .95rem 1rem;
            }

                .content > .container-fluid,
                .content-header > .container-fluid {
                    padding-left: 0;
                    padding-right: 0;
                }

            .page-hero {
                background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(248,251,255,.96));
                border: 1px solid var(--admin-border);
                border-radius: 20px;
                box-shadow: var(--shadow-sm);
                padding: .95rem 1.1rem;
            }

            .page-title {
                margin: 0;
                font-size: 1.15rem;
                font-weight: 800;
                letter-spacing: -.02em;
                color: var(--admin-text);
            }

            .page-subtitle {
                margin-top: .28rem;
                color: var(--admin-text-soft);
                font-size: .88rem;
                line-height: 1.45;
            }

            .page-chip {
                display: inline-flex;
                align-items: center;
                gap: .45rem;
                padding: .55rem .9rem;
                border-radius: 999px;
                background: rgba(37,99,235,.08);
                color: var(--admin-primary-2);
                font-weight: 700;
                font-size: .84rem;
                white-space: nowrap;
            }

            .admin-toggle-btn,
            .admin-profile-shortcut,
            .admin-navbar-dropdown-btn,
            .admin-user-pill,
            .user-identity-chip {
                height: 46px;
                display: inline-flex;
                align-items: center;
                box-shadow: var(--shadow-sm);
                vertical-align: middle;
            }

            .admin-toggle-btn {
                width: 46px;
                justify-content: center;
                border: 1px solid rgba(15,23,42,.08);
                border-radius: 16px;
                background: rgba(255,255,255,.92);
                color: var(--admin-text);
                position: relative;
                cursor: pointer;
                transition: all .22s ease;
            }

                .admin-toggle-btn:hover {
                    transform: translateY(-1px);
                    color: var(--admin-primary);
                    background: #fff;
                }

            .toggle-icon-open,
            .toggle-icon-close {
                position: absolute;
                transition: all .24s ease;
                font-size: 1rem;
            }

            body:not(.sidebar-collapse) .toggle-icon-open {
                opacity: 1;
                transform: scale(1) rotate(0deg);
            }

            body:not(.sidebar-collapse) .toggle-icon-close {
                opacity: 0;
                transform: scale(.7) rotate(-90deg);
            }

            body.sidebar-collapse .toggle-icon-open {
                opacity: 0;
                transform: scale(.7) rotate(90deg);
            }

            body.sidebar-collapse .toggle-icon-close {
                opacity: 1;
                transform: scale(1) rotate(0deg);
            }

            .admin-profile-shortcut {
                padding: 0 1rem;
                border-radius: 16px;
                border: 1px solid rgba(15,23,42,.08);
                background: linear-gradient(135deg, #ffffff, #f8fbff);
                color: var(--admin-text);
                gap: .65rem;
                text-decoration: none;
                font-weight: 800;
                transition: all .22s ease;
            }

                .admin-profile-shortcut:hover {
                    transform: translateY(-1px);
                    color: var(--admin-primary);
                    background: #fff;
                    text-decoration: none;
                }

                .admin-profile-shortcut .icon {
                    width: 28px;
                    height: 28px;
                    border-radius: 10px;
                    background: linear-gradient(135deg, rgba(37,99,235,.12), rgba(124,58,237,.12));
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    color: var(--admin-primary);
                    font-size: .9rem;
                }

            .admin-search {
                position: relative;
                width: min(270px, 26vw);
            }

                .admin-search input {
                    width: 100%;
                    height: 46px;
                    border-radius: 14px;
                    border: 1px solid rgba(15,23,42,.08);
                    background: rgba(255,255,255,.88);
                    padding: .75rem 1rem .75rem 2.75rem;
                    color: var(--admin-text);
                    box-shadow: var(--shadow-sm);
                    outline: none;
                    transition: all .2s ease;
                }

                    .admin-search input:focus {
                        background: #fff;
                        border-color: rgba(37,99,235,.28);
                        box-shadow: 0 0 0 4px rgba(37,99,235,.08);
                    }

                .admin-search i {
                    position: absolute;
                    left: .95rem;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: .9rem;
                }

            .admin-navbar-dropdown-btn {
                padding: 0 .95rem;
                border-radius: 14px;
                border: 1px solid rgba(15,23,42,.08);
                background: rgba(255,255,255,.9);
                color: var(--admin-text);
                gap: .65rem;
                font-weight: 800;
                text-decoration: none;
            }

                .admin-navbar-dropdown-btn:hover {
                    background: #fff;
                    color: var(--admin-primary);
                    text-decoration: none;
                }

            .admin-user-pill {
                padding: 0 .45rem 0 .35rem;
                background: rgba(255,255,255,.9);
                border: 1px solid rgba(15,23,42,.08);
                border-radius: 999px;
                gap: .7rem;
            }

            .admin-user-pill-avatar {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: linear-gradient(135deg, #2563eb, #7c3aed);
                color: #fff;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                font-size: .78rem;
                flex-shrink: 0;
            }

            .admin-user-pill-name {
                font-weight: 800;
                color: var(--admin-text);
                font-size: .92rem;
                max-width: 160px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                line-height: 1;
            }

            .user-identity-chip {
                gap: .6rem;
                padding: 0 1rem;
                border-radius: 999px;
                background: rgba(37,99,235,.08);
                color: var(--admin-primary-2);
                font-weight: 800;
                font-size: .88rem;
                white-space: nowrap;
            }

                .user-identity-chip .dot {
                    width: 10px;
                    height: 10px;
                    border-radius: 50%;
                    background: var(--admin-success);
                    box-shadow: 0 0 0 4px rgba(22,163,74,.14);
                    flex-shrink: 0;
                }

            .dropdown-menu-modern {
                min-width: 250px;
                padding: .6rem;
                border-radius: 18px;
                border: 1px solid rgba(15,23,42,.08);
                box-shadow: 0 22px 50px rgba(15,23,42,.14);
            }

                .dropdown-menu-modern .dropdown-header {
                    padding: .25rem .35rem .55rem;
                    font-size: .75rem;
                    font-weight: 800;
                    color: #94a3b8;
                    letter-spacing: .08em;
                    text-transform: uppercase;
                }

                .dropdown-menu-modern .dropdown-item {
                    border-radius: 14px;
                    padding: .78rem .85rem;
                    font-weight: 700;
                    color: var(--admin-text);
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                }

                    .dropdown-menu-modern .dropdown-item:hover {
                        background: rgba(37,99,235,.08);
                        color: var(--admin-primary);
                    }

                    .dropdown-menu-modern .dropdown-item small {
                        color: var(--admin-text-soft);
                        font-weight: 600;
                    }

            .dropdown-divider-soft {
                margin: .45rem 0;
                border-top: 1px solid rgba(15,23,42,.06);
            }

            .main-footer {
                background: transparent;
                border-top: 0;
                color: var(--admin-text-soft);
                text-align: center;
                padding: .2rem 1rem .9rem;
                font-size: .88rem;
            }

            @@media (max-width: 1199.98px) {
                .admin-search {
                    width: 220px;
                }
            }

            @@media (max-width: 991.98px) {
                .admin-search,
                .user-identity-chip,
                .admin-navbar-dropdown-btn .label,
                .admin-profile-shortcut .label {
                    display: none !important;
                }

                .content-header {
                    padding: .75rem .8rem 0;
                }

                .content {
                    padding: .75rem .8rem .9rem;
                }
            }

            @@media (max-width: 767.98px) {
                .main-header.navbar {
                    padding: 0 .7rem;
                }

                .page-hero {
                    padding: .85rem .9rem;
                }

                .page-title {
                    font-size: 1rem;
                }

                .page-chip {
                    margin-top: .5rem;
                }
            }

            .nav-treeview {
                margin-top: .35rem;
            }

                .nav-treeview .nav-link {
                    min-height: 42px;
                    padding: .75rem .9rem;
                    border-radius: 12px;
                    color: rgba(255,255,255,.72);
                    margin-bottom: .25rem;
                }

                    .nav-treeview .nav-link:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                    }

                    .nav-treeview .nav-link.active {
                        background: rgba(255,255,255,.12);
                        color: #fff !important;
                        box-shadow: none;
                    }

            .nav-sidebar .nav-link > p > .right {
                position: absolute;
                right: 1rem;
                top: 50%;
                transform: translateY(-50%);
            }

            .theory-tree > .nav-link {
                position: relative;
            }

                .theory-tree > .nav-link p {
                    position: relative;
                    width: 100%;
                    padding-right: 28px;
                    margin: 0;
                    display: flex;
                    align-items: center;
                }

                .theory-tree > .nav-link .theory-arrow {
                    position: absolute;
                    right: 0;
                    top: 50%;
                    transform: translateY(-50%);
                    margin: 0 !important;
                    font-size: .82rem;
                    transition: transform .22s ease;
                }

            .theory-tree.menu-open > .nav-link .theory-arrow {
                transform: translateY(-50%) rotate(180deg);
            }

            .theory-treeview {
                position: relative;
                margin-top: .4rem;
                margin-left: .95rem;
                padding-left: 1.45rem;
            }

                .theory-treeview::before {
                    content: "";
                    position: absolute;
                    top: .2rem;
                    bottom: .55rem;
                    left: .5rem;
                    width: 1px;
                    background: rgba(255,255,255,.16);
                }

                .theory-treeview .nav-item {
                    position: relative;
                }

                    .theory-treeview .nav-item::before {
                        content: "";
                        position: absolute;
                        left: -.52rem;
                        top: 50%;
                        width: 8px;
                        height: 8px;
                        border-radius: 50%;
                        background: #5ea2ff;
                        border: 2px solid #102a57;
                        transform: translateY(-50%);
                        z-index: 2;
                    }

                .theory-treeview .nav-link {
                    min-height: 42px;
                    padding: .78rem .9rem .78rem .95rem;
                    margin-bottom: .28rem;
                    border-radius: 12px;
                    color: rgba(255,255,255,.76);
                    background: transparent;
                    display: flex;
                    align-items: center;
                }

                    .theory-treeview .nav-link .nav-icon {
                        width: 22px;
                        margin-right: .7rem;
                        font-size: .95rem;
                        text-align: center;
                    }

                    .theory-treeview .nav-link:hover {
                        background: rgba(255,255,255,.06);
                        color: #fff;
                    }

                    .theory-treeview .nav-link.active {
                        background: rgba(255,255,255,.10);
                        color: #fff !important;
                        box-shadow: none;
                    }

                    .theory-treeview .nav-link p {
                        margin: 0;
                        line-height: 1.2;
                    }

            .nav-sidebar .nav-link > p > .right {
                margin-left: auto !important;
            }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item me-2">
                    <a class="admin-toggle-btn" data-widget="pushmenu" href="#" role="button" id="sidebarToggleBtn">
                        <i class="fa-solid fa-bars-staggered toggle-icon-open"></i>
                        <i class="fa-solid fa-sliders toggle-icon-close"></i>
                    </a>
                </li>

                <li class="nav-item me-2">
                    <a asp-controller="AdminUser" asp-action="Index" class="admin-profile-shortcut">
                        <span class="icon">
                            <i class="fa-solid fa-user-shield"></i>
                        </span>
                        <span class="label">AdminUser</span>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item me-2">
                    <div class="admin-search">
                        <i class="fa fa-magnifying-glass"></i>
                        <input type="text" placeholder="Tìm chức năng..." />
                    </div>
                </li>

                <li class="nav-item me-2">
                    <div class="user-identity-chip">
                        <span class="dot"></span>
                        <span>@username</span>
                    </div>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link p-0 d-flex align-items-center" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false" style="height:46px;">
                        <div class="admin-user-pill">
                            <span class="admin-user-pill-avatar">@initials</span>
                            <span class="admin-user-pill-name">@username</span>
                            <i class="fa fa-angle-down text-muted me-1"></i>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-modern">
                        <li class="dropdown-header">Tài khoản</li>

                        <li>
                            <a class="dropdown-item" asp-controller="AdminDashboard" asp-action="Index">
                                <span><i class="fa-solid fa-house me-2 text-primary"></i> Trang quản trị</span>
                                <small>Home</small>
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" asp-controller="AdminProfiles" asp-action="Index">
                                <span><i class="fa-solid fa-user-gear me-2 text-primary"></i> Thông tin quản trị</span>
                                <small>Profile</small>
                            </a>
                        </li>

                        <li><hr class="dropdown-divider dropdown-divider-soft" /></li>

                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                <span><i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất</span>
                                <small>Exit</small>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar elevation-4">
            <a asp-controller="AdminDashboard" asp-action="Index" class="brand-link">
                <div class="brand-wrap">
                    <div class="brand-logo-shell">
                        <img src="~/images/logo/logo-mini.png" alt="Logo" />
                    </div>

                    <div class="brand-text-wrap">
                        <span class="brand-title">Admin Panel</span>
                        <span class="brand-subtitle">Management System</span>
                    </div>
                </div>
            </a>

            <div class="sidebar">
                <div class="admin-user-card">
                    <div class="admin-avatar">@initials</div>
                    <div class="admin-user-meta">
                        <p class="admin-user-name">@username</p>
                        <div class="admin-user-role">Quản trị hệ thống</div>
                    </div>
                </div>

                <div class="menu-section-label">Điều hướng</div>

                <nav class="mt-1">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">

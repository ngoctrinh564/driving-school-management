@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- LOGO TAB -->
    <link rel="icon" href="~/images/logo/logo-mini.png" />
    <link rel="apple-touch-icon" href="~/images/logo/logo-mini.png" />

    <title>@ViewData["Title"] - Admin</title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" rel="stylesheet" />

    <style>
            body {
                font-family: 'Segoe UI', Roboto, sans-serif;
            }

            .sidebar .nav-link.active {
                background: #0d6efd;
                color: #fff;
                font-weight: 600;
            }

            /* ===== LOGO ===== */
            .brand-link {
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 6px 0;
            }

            #logoFull {
                max-width: 140px;
            }

            #logoMini {
                display: none;
                max-width: 36px;
            }

            .sidebar-collapse #logoFull {
                display: none;
            }

            .sidebar-collapse #logoMini {
                display: inline-block;
            }

            /* ===== FIX NAVBAR + SIDEBAR ===== */
            .layout-navbar-fixed .main-sidebar {
                top: 57px;
            }

            /* ===== CONTENT ===== */
            .content-wrapper {
                background: #f4f6f9;
            }
    </style>
</head>

<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
    <div class="wrapper">

        <!-- NAVBAR -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light shadow-sm">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu">
                        <i class="fa fa-bars"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">
                <li class="nav-item d-flex align-items-center me-3">
                    <span class="fw-semibold text-primary">@username</span>
                </li>
                <li class="nav-item">
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                        <i class="fa fa-right-from-bracket"></i>
                    </a>
                </li>
            </ul>
        </nav>

        <!-- SIDEBAR -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">

            <!-- LOGO -->
            <a asp-controller="AdminDashboard" asp-action="Index" class="brand-link">
                <img id="logoFull" src="~/images/logo/logo-full.png" />
                <img id="logoMini" src="~/images/logo/logo-mini.png" />
            </a>

            <div class="sidebar">

                <!-- MENU -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column">

                        <li class="nav-item">
                            <a asp-controller="AdminDashboard" asp-action="Index"
                                   class="nav-link @(currentController == "AdminDashboard" ? "active" : "")">
                                <i class="nav-icon fa fa-gauge"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="AdminUser" asp-action="Index"
                                   class="nav-link @(currentController == "AdminUser" ? "active" : "")">
                                <i class="nav-icon fa fa-users"></i>
                                <p>Người dùng</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="AdminExam" asp-action="Index"
                                   class="nav-link @(currentController == "AdminExam" ? "active" : "")">
                                <i class="nav-icon fa fa-file-alt"></i>
                                <p>Kỳ thi</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="AdminCourses" asp-action="Index"
                                   class="nav-link @(currentController == "AdminCourses" ? "active" : "")">
                                <i class="nav-icon fa fa-book"></i>
                                <p>Khóa học</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="AdminProfiles" asp-action="Index"
                                   class="nav-link @(currentController == "AdminProfiles" ? "active" : "")">
                                <i class="nav-icon fa fa-id-card"></i>
                                <p>Hồ sơ</p>
                            </a>
                        </li>

                        <li class="nav-item mt-3">
                            <a asp-controller="Auth" asp-action="Logout" class="nav-link text-danger">
                                <i class="nav-icon fa fa-right-from-bracket"></i>
                                <p>Đăng xuất</p>
                            </a>
                        </li>

                    </ul>
                </nav>

            </div>
        </aside>

        <!-- CONTENT -->
        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid py-2">
                    <h4 class="fw-bold text-primary">@ViewData["Title"]</h4>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- FOOTER -->
        <footer class="main-footer text-center">
            © @DateTime.Now.Year - Admin System
        </footer>

    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
    @await Html.PartialAsync("_Toast")

</body>
</html>
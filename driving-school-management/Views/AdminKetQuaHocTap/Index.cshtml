@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalKqhtButtons = document.querySelectorAll('.btn-open-kqht');
            const modalCtButtons = document.querySelectorAll('.btn-open-ctkqht');

            modalKqhtButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    document.getElementById('kqhtId').value = this.dataset.id || '';
                    document.getElementById('kqhtHoTen').textContent = this.dataset.hoten || '';
                    document.getElementById('kqhtHoSo').textContent = this.dataset.hoso || '';
                    document.getElementById('kqhtSoBuoiHoc').value = this.dataset.sobuoihoc || 0;
                    document.getElementById('kqhtSoBuoiToiThieu').textContent = this.getAttribute('data-sobuoi-toithieu') || '';
                    document.getElementById('kqhtSoKmHoanThanh').value = this.dataset.sokm || 0;
                    document.getElementById('kqhtKmToiThieu').textContent = this.dataset.kmtoithieu || '';
                    document.getElementById('kqhtNhanXet').value = this.dataset.nhanxet || '';
                });
            });

            function setRadioValue(groupName, value) {
                const radioValue = value === 'true' ? '1' : '0';
                const radio = document.querySelector(`input[name="${groupName}"][value="${radioValue}"]`);
                if (radio) {
                    radio.checked = true;
                }
            }

            function disableRadioGroup(groupName, disabled) {
                document.querySelectorAll(`input[name="${groupName}"]`).forEach(radio => {
                    radio.disabled = disabled;
                });
            }

            modalCtButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const duDk = this.dataset.dudk === 'true';
                    const dauTn = this.dataset.dautn === 'true';
                    const dkSh = this.dataset.dksh === 'true';
                    const lyThuyet = this.dataset.lythuyet === 'true';
                    const saHinh = this.dataset.sahinh === 'true';
                    const duongTruong = this.dataset.duongtruong === 'true';
                    const moPhong = this.dataset.mophong === 'true';

                    document.getElementById('ctkqhtId').value = this.dataset.id || '';
                    document.getElementById('ctkqhtHoTen').textContent = this.dataset.hoten || '';
                    document.getElementById('ctkqhtHoSo').textContent = this.dataset.hoso || '';
                    document.getElementById('ctkqhtDuDk').textContent = duDk ? 'Đủ điều kiện' : 'Chưa đủ điều kiện';

                    let giaiDoan = 'Thi tốt nghiệp';

                    if (dauTn && dkSh) {
                        giaiDoan = 'Thi sát hạch';
                    }

                    if (dauTn && dkSh && lyThuyet && saHinh && duongTruong && moPhong) {
                        giaiDoan = 'Hoàn thành - chờ cấp bằng';
                    }

                    document.getElementById('ctkqhtGiaiDoan').textContent = giaiDoan;

                    setRadioValue('LyThuyetKq', this.dataset.lythuyet);
                    setRadioValue('SaHinhKq', this.dataset.sahinh);
                    setRadioValue('DuongTruongKq', this.dataset.duongtruong);
                    setRadioValue('MoPhongKq', this.dataset.mophong);

                    const btnSubmit = document.getElementById('btnSubmitChiTiet');

                    if (!duDk) {
                        btnSubmit.disabled = true;
                        btnSubmit.classList.add('disabled');

                        disableRadioGroup('LyThuyetKq', true);
                        disableRadioGroup('SaHinhKq', true);
                        disableRadioGroup('DuongTruongKq', true);
                        disableRadioGroup('MoPhongKq', true);
                    } else {
                        btnSubmit.disabled = false;
                        btnSubmit.classList.remove('disabled');

                        disableRadioGroup('LyThuyetKq', false);
                        disableRadioGroup('SaHinhKq', false);
                        disableRadioGroup('DuongTruongKq', false);
                        disableRadioGroup('MoPhongKq', false);
                    }
                });
            });
        });
    </script>
}
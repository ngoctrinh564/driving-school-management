@{
    ViewData["Title"] = "Chatbot AI";

    var rawAvatarUrl = ViewBag.AvatarUrl?.ToString();

    string userAvatarUrl;

    if (string.IsNullOrWhiteSpace(rawAvatarUrl))
    {
        userAvatarUrl = Url.Content("~/images/avatar/default.png");
    }
    else if (rawAvatarUrl.StartsWith("~/"))
    {
        userAvatarUrl = Url.Content(rawAvatarUrl);
    }
    else if (rawAvatarUrl.StartsWith("/"))
    {
        userAvatarUrl = Url.Content("~" + rawAvatarUrl);
    }
    else
    {
        userAvatarUrl = Url.Content("~/" + rawAvatarUrl.TrimStart('/'));
    }
}

<style>
    :root {
        --bg: #f4f6f8;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --surface-muted: #f1f5f9;
        --text: #0f172a;
        --text-soft: #475569;
        --text-muted: #64748b;
        --border: rgba(148, 163, 184, 0.18);
        --border-strong: rgba(100, 116, 139, 0.24);
        --accent: #0f172a;
        --accent-soft: rgba(15, 23, 42, 0.06);
        --focus: rgba(37, 99, 235, 0.14);
        --shadow-sm: 0 8px 20px rgba(15, 23, 42, 0.05);
        --shadow-md: 0 16px 40px rgba(15, 23, 42, 0.08);
        --radius-sm: 14px;
        --radius-md: 18px;
        --radius-lg: 24px;
        --radius-xl: 28px;
        --transition: all .22s ease;
    }

    html, body {
        height: 100%;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(255,255,255,.9) 0%, rgba(255,255,255,0) 30%), linear-gradient(180deg, #f8fafc 0%, #f2f5f8 100%);
        font-family: Inter, "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
    }

    .chatbot-page {
        min-height: 100vh;
        padding: 24px;
        display: flex;
        align-items: stretch;
        justify-content: center;
    }

    .chatbot-shell {
        width: min(980px, 100%);
        height: calc(100vh - 48px);
        min-height: 680px;
        background: rgba(255,255,255,.88);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        overflow: hidden;
    }

    .chatbot-header {
        padding: 20px 22px;
        border-bottom: 1px solid var(--border);
        background: rgba(255,255,255,.75);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .chatbot-header-main {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .chatbot-icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid var(--border);
        color: var(--accent);
        box-shadow: var(--shadow-sm);
        flex: 0 0 auto;
    }

    .chatbot-header-text {
        min-width: 0;
    }

    .chatbot-title {
        margin: 0 0 6px;
        font-size: 22px;
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -.02em;
        color: var(--text);
    }

    .chatbot-subtitle {
        margin: 0;
        font-size: 14px;
        color: var(--text-soft);
        line-height: 1.55;
    }

    .chatbot-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 0 0 auto;
    }

    .btn-clean {
        height: 42px;
        padding: 0 16px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 4px 12px rgba(15, 23, 42, .03);
    }

        .btn-clean:hover {
            border-color: var(--border-strong);
            background: var(--surface-soft);
            transform: translateY(-1px);
        }

    .chatbot-body {
        min-height: 0;
        background: linear-gradient(180deg, rgba(248,250,252,.75) 0%, rgba(244,246,248,.5) 100%);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .chat-scroll {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 24px 22px;
        scroll-behavior: smooth;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

        .chat-scroll::-webkit-scrollbar {
            width: 10px;
        }

        .chat-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .chat-scroll::-webkit-scrollbar-thumb {
            background: rgba(148, 163, 184, .34);
            border-radius: 999px;
            border: 2px solid transparent;
            background-clip: content-box;
        }

    .welcome-block {
        background: linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(248,250,252,.94) 100%);
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .04);
    }

    .welcome-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--text-soft);
        border: 1px solid rgba(15, 23, 42, .05);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .04em;
        margin-bottom: 14px;
    }

    .welcome-title {
        margin: 0 0 8px;
        font-size: 20px;
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -.02em;
        color: var(--text);
    }

    .welcome-text {
        margin: 0;
        font-size: 14px;
        color: var(--text-soft);
        line-height: 1.7;
        max-width: 760px;
    }

    .suggestion-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
    }

    .suggestion-chip {
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        border-radius: 999px;
        padding: 10px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 4px 14px rgba(15, 23, 42, .03);
    }

        .suggestion-chip:hover {
            border-color: var(--border-strong);
            background: var(--surface-soft);
            transform: translateY(-1px);
        }

    .message-row {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        max-width: 100%;
    }

        .message-row.bot {
            justify-content: flex-start;
        }

        .message-row.user {
            justify-content: flex-end;
        }

    .message-avatar,
    .message-chat-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        flex: 0 0 auto;
        border: 1px solid var(--border);
        box-shadow: 0 8px 18px rgba(15, 23, 42, .04);
        overflow: hidden;
    }

    .message-chat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        color: var(--accent);
    }

    .message-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        background: #fff;
    }

    .message-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-width: min(78%, 760px);
    }

    .message-row.user .message-stack {
        align-items: flex-end;
    }

    .message-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 4px;
        font-size: 12px;
        color: var(--text-muted);
    }

    .message-name {
        font-weight: 700;
        color: var(--text-soft);
    }

    .message-bubble {
        padding: 14px 16px;
        border-radius: 18px;
        font-size: 14.5px;
        line-height: 1.7;
        white-space: pre-wrap;
        word-break: break-word;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .04);
    }

    .message-row.bot .message-bubble {
        background: rgba(255,255,255,.96);
        color: var(--text);
        border: 1px solid rgba(148, 163, 184, .16);
        border-bottom-left-radius: 8px;
    }

    .message-row.user .message-bubble {
        background: linear-gradient(180deg, #162033 0%, #0f172a 100%);
        color: #f8fafc;
        border: 1px solid rgba(15, 23, 42, .85);
        border-bottom-right-radius: 8px;
        box-shadow: 0 16px 36px rgba(15, 23, 42, .16);
    }

    .typing-bubble {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 18px;
    }

        .typing-bubble span {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #94a3b8;
            display: inline-block;
            animation: chatTyping 1.1s infinite ease-in-out;
        }

            .typing-bubble span:nth-child(2) {
                animation-delay: .15s;
            }

            .typing-bubble span:nth-child(3) {
                animation-delay: .3s;
            }

    @@keyframes chatTyping {
        0%, 80%, 100% {
            transform: translateY(0);
            opacity: .55;
        }

        40% {
            transform: translateY(-4px);
            opacity: 1;
        }
    }

    .chatbot-footer {
        padding: 18px 22px 22px;
        border-top: 1px solid var(--border);
        background: rgba(255,255,255,.8);
    }

    .input-shell {
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, .18);
        background: rgba(255,255,255,.96);
        box-shadow: 0 14px 30px rgba(15, 23, 42, .05);
        padding: 12px;
    }

    .input-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: end;
    }

    .input-main {
        min-width: 0;
    }

        .input-main textarea {
            width: 100%;
            min-height: 54px;
            max-height: 150px;
            resize: none;
            border: none;
            outline: none;
            background: transparent;
            font-size: 15px;
            line-height: 1.6;
            color: var(--text);
            padding: 8px 6px;
            overflow-y: auto;
        }

            .input-main textarea::placeholder {
                color: var(--text-muted);
            }

    .input-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 0 6px 2px;
    }

    .input-hint {
        font-size: 12px;
        color: var(--text-muted);
    }

    .input-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        border-radius: 999px;
        background: var(--surface-muted);
        border: 1px solid var(--border);
        color: var(--text-soft);
        font-size: 12px;
        font-weight: 600;
    }

    .send-btn {
        min-width: 118px;
        height: 54px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(180deg, #162033 0%, #0f172a 100%);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0 20px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 18px 30px rgba(15, 23, 42, .15);
    }

        .send-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 34px rgba(15, 23, 42, .18);
        }

        .send-btn:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    @@media (max-width: 768px) {
        .chatbot-page {
            padding: 12px;
        }

        .chatbot-shell {
            width: 100%;
            height: calc(100vh - 24px);
            min-height: 0;
            border-radius: 22px;
        }

        .chatbot-header {
            padding: 16px;
            align-items: flex-start;
            flex-direction: column;
        }

        .chat-scroll {
            padding: 16px;
        }

        .chatbot-footer {
            padding: 14px 16px 16px;
        }

        .message-stack {
            max-width: 88%;
        }

        .input-grid {
            grid-template-columns: 1fr;
        }

        .send-btn {
            width: 100%;
        }

        .input-meta {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    .message-chat-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .chatbot-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: inherit;
    }
</style>

<div class="chatbot-page">
    <div class="chatbot-shell">
        <div class="chatbot-header">
            <div class="chatbot-header-main">
                <div class="chatbot-icon">
                    <img src="/images/avatar/chatbot.png" alt="chatbot" onerror="this.onerror=null;this.src='/images/avatar/default.png';" />
                </div>
                <div class="chatbot-header-text">
                    <h1 class="chatbot-title">Chatbot AI GPLX</h1>
                    <p class="chatbot-subtitle">Trợ lý hội thoại cho hệ thống đào tạo và ôn thi giấy phép lái xe tại Việt Nam.</p>
                </div>
            </div>

            <div class="chatbot-actions">
                <button type="button" class="btn-clean" onclick="newChat()">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>Chat mới</span>
                </button>
            </div>
        </div>

        <div class="chatbot-body">
            <div id="chatScroll" class="chat-scroll"></div>
        </div>

        <div class="chatbot-footer">
            <div class="input-shell">
                <div class="input-grid">
                    <div class="input-main">
                        <textarea id="messageInput" rows="1" placeholder="Nhập câu hỏi về giấy phép lái xe và nhấn Enter..." autocomplete="off"></textarea>
                        <div class="input-meta">
                            <div class="input-hint">Enter để gửi • Shift + Enter để xuống dòng</div>
                            
                            <div class="input-badge">
                                <i class="fa-solid fa-shield"></i>
                                <span>Phiên trò chuyện</span>
                            </div>
                        </div>
                    </div>

                    <button id="sendBtn" type="button" class="send-btn" onclick="sendMessage()">
                        <i class="fa-solid fa-paper-plane"></i>
                        <span>Gửi</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const chatScroll = document.getElementById("chatScroll");
    const input = document.getElementById("messageInput");
    const sendBtn = document.getElementById("sendBtn");
    const userAvatarUrl = '@userAvatarUrl';
    const defaultAvatarUrl = '@Url.Content("~/images/avatar/default.png")';

    function escapeHtml(s) {
        return (s ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    function formatText(text) {
        return escapeHtml(text).replace(/\n/g, "<br>");
    }

    function currentTimeLabel() {
        const now = new Date();
        return now.toLocaleTimeString("vi-VN", {
            hour: "2-digit",
            minute: "2-digit"
        });
    }

    function scrollToBottom() {
        chatScroll.scrollTop = chatScroll.scrollHeight;
    }

    function autoResizeTextarea() {
        input.style.height = "auto";
        input.style.height = Math.min(input.scrollHeight, 150) + "px";
    }

    function removeWelcomeIfExists() {
        const welcome = chatScroll.querySelector(".welcome-block");
        if (welcome) welcome.remove();
    }

    function addWelcomeBlock() {
        const welcome = document.createElement("div");
        welcome.className = "welcome-block";
        welcome.innerHTML = `
            <div class="welcome-label">
                <i class="fa-solid fa-sparkles"></i>
                <span>Trợ lý AI</span>
            </div>
            <h2 class="welcome-title">Bắt đầu hội thoại với trợ lý GPLX</h2>
            <p class="welcome-text">
                Đặt câu hỏi về hạng giấy phép lái xe, điều kiện thi, hồ sơ đăng ký, quy trình thi, luật giao thông hoặc các câu hỏi trắc nghiệm liên quan.
            </p>
            <div class="suggestion-list">
                <button type="button" class="suggestion-chip" onclick="applySuggestion('Điều kiện thi giấy phép lái xe hạng B là gì')">Điều kiện thi hạng B</button>
                <button type="button" class="suggestion-chip" onclick="applySuggestion('Hồ sơ đăng ký học và thi GPLX gồm những gì')">Hồ sơ đăng ký</button>
                <button type="button" class="suggestion-chip" onclick="applySuggestion('Quy trình thi lý thuyết và thực hành GPLX như thế nào')">Quy trình thi</button>
                <button type="button" class="suggestion-chip" onclick="applySuggestion('Giải thích cho tôi một câu hỏi trắc nghiệm GPLX')">Câu hỏi trắc nghiệm</button>
            </div>
        `;
        chatScroll.appendChild(welcome);
    }

    function applySuggestion(text) {
        input.value = text;
        autoResizeTextarea();
        input.focus();
    }

    function createUserAvatar() {
        const avatar = document.createElement("div");
        avatar.className = "message-avatar";

        const img = document.createElement("img");
        img.src = userAvatarUrl;
        img.alt = "avatar người dùng";

        img.onerror = function () {
            this.onerror = null;
            this.src = defaultAvatarUrl;
        };

        avatar.appendChild(img);
        return avatar;
    }

    function createBotIcon() {
        const icon = document.createElement("div");
        icon.className = "message-chat-icon";

        const img = document.createElement("img");
        img.src = "/images/avatar/chatbot.png";
        img.alt = "chatbot";

        img.onerror = function () {
            this.onerror = null;
            this.src = "/images/avatar/default.png";
        };

        icon.appendChild(img);
        return icon;
    }

    function addMessage(text, type, opts = {}) {
        const row = document.createElement("div");
        row.className = `message-row ${type}`;

        const stack = document.createElement("div");
        stack.className = "message-stack";

        const meta = document.createElement("div");
        meta.className = "message-meta";
        meta.innerHTML = `
            <span class="message-name">${type === "bot" ? "Chatbot AI" : "Bạn"}</span>
            <span>•</span>
            <span>${currentTimeLabel()}</span>
        `;

        const bubble = document.createElement("div");
        bubble.className = "message-bubble";
        bubble.innerHTML = opts.rawHtml === true ? text : formatText(text);

        stack.appendChild(meta);
        stack.appendChild(bubble);

        if (type === "bot") {
            row.appendChild(createBotIcon());
            row.appendChild(stack);
        } else {
            row.appendChild(stack);
            row.appendChild(createUserAvatar());
        }

        chatScroll.appendChild(row);
        scrollToBottom();
        return row;
    }

    function addTyping() {
        const html = `
            <div class="typing-bubble" aria-label="typing">
                <span></span>
                <span></span>
                <span></span>
            </div>`;
        return addMessage(html, "bot", { rawHtml: true });
    }

    function newChat() {
        chatScroll.innerHTML = "";
        addWelcomeBlock();
        addMessage("Xin chào. Tôi là trợ lý AI hỗ trợ nội dung GPLX tại Việt Nam. Hãy nhập câu hỏi của bạn.", "bot");
        input.value = "";
        autoResizeTextarea();
        input.focus();
    }

    async function sendMessage() {
        const text = input.value.trim();
        if (!text) return;

        removeWelcomeIfExists();
        addMessage(text, "user");

        input.value = "";
        autoResizeTextarea();
        input.disabled = true;
        sendBtn.disabled = true;

        const typingMsg = addTyping();

        try {
            const res = await fetch("/Chatbot/SendMessage", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ message: text })
            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok) {
                throw new Error(data.detail || data.error || "Lỗi không xác định");
            }

            typingMsg.remove();
            addMessage(data.reply ?? "", "bot");
        } catch (err) {
            typingMsg.remove();
            addMessage("Không thể xử lý yêu cầu. " + (err?.message ?? "Lỗi không xác định"), "bot");
        } finally {
            input.disabled = false;
            sendBtn.disabled = false;
            input.focus();
            scrollToBottom();
        }
    }

    input.addEventListener("input", autoResizeTextarea);

    input.addEventListener("keydown", function (e) {
        if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    newChat();
    autoResizeTextarea();
</script>
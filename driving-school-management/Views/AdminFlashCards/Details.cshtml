@model driving_school_management.ViewModels.FlashCardDetailVM

@{
    ViewData["Title"] = "Chi tiết Flashcard biển báo";
    var stt = 1;
}

<section class="content">
    <div class="container-fluid admin-flashcard-detail-page">

        <div class="page-header-card mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="page-caption">Quản lý Flashcard</div>
                    <h3 class="page-title mb-1">Chi tiết Flashcard biển báo</h3>
                </div>

                <a asp-action="Index" class="btn btn-secondary btn-admin-action btn-admin-back">
                    <i class="fa fa-arrow-left"></i>
                    <span>Quay lại danh sách</span>
                </a>
            </div>
        </div>

        <div class="card admin-card border-0 mb-4">
            <div class="card-body p-3 p-lg-4">
                <div class="detail-sign-wrapper">
                    <div class="detail-sign-image-box">
                        @if (!string.IsNullOrEmpty(Model.HinhAnh))
                        {
                            <img src="@Url.Content("~/" + Model.HinhAnh.TrimStart('/'))"
                                 alt="@Model.TenBienBao"
                                 class="detail-sign-image" />
                        }
                        else
                        {
                            <div class="sign-empty-image">Chưa có ảnh</div>
                        }
                    </div>

                    <div class="detail-sign-content">
                        <div class="detail-sign-name">@Model.TenBienBao</div>
                        <div class="detail-sign-meaning">@Model.Ynghia</div>

                        <div class="detail-info-row">
                            <div class="detail-info-chip">
                                Tổng lượt đánh giá: <strong> @Model.Items.Count</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card admin-card border-0">
            <div class="card-body p-3 p-lg-4">
                <div class="table-responsive">
                    <table class="table admin-detail-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 100px;" class="text-center">Số thứ tự</th>
                                <th>Họ tên</th>
                                <th style="width: 240px;" class="text-center">Trạng thái ghi nhớ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="text-center stt-cell">@stt</td>

                                        <td>
                                            <div class="user-info-wrap">
                                                <div class="user-display-name">@item.HoTen</div>
                                                <div class="user-meta">Mã người dùng: @item.UserId</div>
                                            </div>
                                        </td>

                                        <td class="text-center">
                                            @if (item.TrangThaiGhiNho == "Đã nhớ")
                                            {
                                                <span class="status-badge status-remembered">Đã nhớ</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-not-remembered">Chưa nhớ</span>
                                            }
                                        </td>
                                    </tr>

                                    stt++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-5">
                                        Chưa có dữ liệu flashcard.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</section>

@section Styles {
    <style>
        .admin-flashcard-detail-page {
            font-family: "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
        }

        .page-header-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.96), rgba(248,250,252,0.92));
            border: 1px solid rgba(15,23,42,0.08);
            border-radius: 20px;
            padding: 20px 24px;
            box-shadow: 0 8px 18px rgba(15,23,42,0.05);
        }

        .page-caption {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #2563eb;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
        }

        .page-subtitle {
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
        }

        .admin-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 8px 18px rgba(15,23,42,0.05);
            border: 1px solid rgba(15,23,42,0.08);
            overflow: hidden;
        }

        .btn-admin-action {
            height: 44px;
            border-radius: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all .2s ease;
            padding: 0 18px;
        }

        .btn-admin-back {
            box-shadow: none;
        }

        .detail-sign-wrapper {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 24px;
            align-items: center;
        }

        .detail-sign-image-box {
            width: 140px;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(15,23,42,0.08);
            border-radius: 18px;
            background: #fff;
            padding: 10px;
        }

        .detail-sign-image {
            width: 112px;
            height: 112px;
            object-fit: contain;
        }

        .sign-empty-image {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px dashed rgba(15,23,42,0.15);
            border-radius: 14px;
            background: #f8fafc;
            color: #94a3b8;
            font-size: 12px;
            font-weight: 600;
            text-align: center;
            padding: 8px;
        }

        .detail-sign-content {
            min-width: 0;
        }

        .detail-sign-name {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.35;
            margin-bottom: 10px;
        }

        .detail-sign-meaning {
            font-size: 15px;
            line-height: 1.75;
            color: #334155;
            margin-bottom: 0;
        }

        .detail-info-row {
            margin-top: 18px;
        }

        .detail-info-chip {
            display: inline-flex;
            align-items: center;
            padding: 10px 16px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 14px;
            font-weight: 700;
        }

        .admin-detail-table {
            margin: 0;
            border-collapse: separate;
            border-spacing: 0;
            table-layout: fixed;
            width: 100%;
        }

            .admin-detail-table thead th {
                background: #f8fafc;
                color: #0f172a;
                font-size: 14px;
                font-weight: 700;
                padding: 16px 18px;
                border-bottom: 1px solid rgba(15,23,42,0.08);
                vertical-align: middle;
            }

            .admin-detail-table tbody td {
                padding: 18px 18px;
                border-bottom: 1px solid rgba(15,23,42,0.08);
                vertical-align: middle;
                background: #fff;
            }

            .admin-detail-table tbody tr:last-child td {
                border-bottom: none;
            }

            .admin-detail-table tbody tr:hover td {
                background: #f8fbff;
            }

        .stt-cell {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
        }

        .user-info-wrap {
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 68px;
        }

        .user-display-name {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.5;
            word-break: break-word;
        }

        .user-meta {
            font-size: 13px;
            color: #64748b;
            margin-top: 4px;
            line-height: 1.5;
        }

        .status-badge {
            min-width: 120px;
            height: 40px;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            padding: 0 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            line-height: 1;
        }

        .status-remembered {
            background: #dcfce7;
            color: #166534;
        }

        .status-not-remembered {
            background: #fee2e2;
            color: #991b1b;
        }

        @@media (max-width: 991.98px) {
            .page-header-card {
                padding: 18px;
            }

            .page-title {
                font-size: 24px;
            }

            .detail-sign-wrapper {
                grid-template-columns: 1fr;
                gap: 18px;
            }

            .detail-sign-image-box {
                width: 120px;
                height: 120px;
            }

            .detail-sign-image {
                width: 96px;
                height: 96px;
            }

            .detail-sign-name {
                font-size: 22px;
            }

            .admin-detail-table thead th,
            .admin-detail-table tbody td {
                padding: 14px 12px;
            }

            .status-badge {
                min-width: 108px;
            }
        }
    </style>
}